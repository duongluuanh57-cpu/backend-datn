# Server Config
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Database & Cache
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/elite_saas
REDIS_URL=redis://default:<password>@<host>:<port>

# AI API Keys
GEMINI_API_KEY=your_gemini_api_key

# Security
JWT_SECRET=your_super_secret_jwt_key
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.onrender.com

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
FRONTEND_URL=http://localhost:3000


# Cloudflare R2 (Lưu trữ và nén ảnh WebP vĩnh viễn)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_PUBLIC_DOMAIN=https://pub-your-bucket-id.r2.dev

# Messaging & Monitoring
QSTASH_TOKEN=your_qstash_token
SENTRY_DSN=your_sentry_dsn
POSTHOG_API_KEY=your_posthog_key
POSTHOG_HOST=https://us.i.posthog.com
