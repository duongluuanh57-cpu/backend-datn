    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@google/genai": "^2.2.0",
    "@google/generative-ai": "^0.24.1",
    "@langchain/core": "^1.1.46",
    "@langchain/google-genai": "^2.1.30",
    "@langchain/langgraph": "^1.3.0",
    "@sentry/node": "^10.53.1",
    "@upstash/qstash": "^2.11.0",
    "ai": "^6.0.184",
