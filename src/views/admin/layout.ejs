<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle || 'Dashboard' %> — L'essence Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=JetBrains+Mono&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/admin/static/admin.css">
  <style>body{margin:0;padding:0;background:#F7F6F3;color:#2F3437;font-family:"Outfit","Inter",system-ui,-apple-system,sans-serif;-webkit-font-smoothing:antialiased;font-feature-settings:"ss01","cv05"}
#toasts{position:fixed;top:80px;right:24px;z-index:999;display:flex;flex-direction:column;gap:8px;}
.toast{padding:12px 20px;border-radius:8px;font-size:14px;font-weight:500;color:#fff;min-width:280px;box-shadow:0 4px 20px rgba(0,0,0,0.10);animation:slideIn .3s ease;display:flex;align-items:center;justify-content:space-between;gap:12px;}
.toast.success{background:#22c55e;}.toast.error{background:#ef4444;}.toast.info{background:#C9A96E;}
.toast .close{background:none;border:none;color:#fff;cursor:pointer;font-size:18px;opacity:.7;line-height:1;}
@keyframes slideIn{from{transform:translateX(100%);opacity:0}to{transform:translateX(0);opacity:1}}
#confirmOverlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.3);z-index:998;align-items:center;justify-content:center}
#confirmOverlay.active{display:flex}
.confirm-box{background:#FFFFFF;border:1px solid var(--color-border-light);border-radius:14px;padding:24px;max-width:400px;width:90%;text-align:center;box-shadow:0 8px 32px rgba(201,169,110,0.08);}
.confirm-box h4{font-size:16px;margin-bottom:8px;color:var(--color-text-primary)}
.confirm-box p{font-size:13px;color:var(--color-text-muted);margin-bottom:20px}
.confirm-box .actions{display:flex;gap:10px;justify-content:center}
.confirm-box .btn-cancel,.confirm-box .btn-confirm{padding:8px 20px;border-radius:8px;border:none;cursor:pointer;font-size:14px;font-weight:500}
.confirm-box .btn-cancel{background:var(--color-surface);color:var(--color-text-primary);border:1px solid var(--color-border-light)}
.confirm-box .btn-cancel:hover{background:rgba(201,169,110,0.06)}
.confirm-box .btn-confirm{background:var(--danger);color:#fff}
.confirm-box .btn-confirm:hover{opacity:0.9}
</style>
</head>
<body>
  <%- include('admin/partials/sidebar', { currentPage: currentPage || 'dashboard' }) %>

  <header class="admin-header">
    <div class="header-left">
      <button class="mobile-toggle" onclick="toggleSidebar()">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <h2><%= pageTitle || 'Dashboard' %></h2>
      <% if (typeof breadcrumb !== 'undefined' && breadcrumb) { %><span class="breadcrumb">/ <%= breadcrumb %></span><% } %>
    </div>
    <div class="header-right">
      <button class="btn-icon" title="Thông báo">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
      </button>
      <div class="user-menu">
        <div class="avatar"><%= userInitials || 'A' %></div>
        <div class="user-info">
          <div class="user-name"><%= userName || 'Admin' %></div>
          <div class="user-role"><%= userRole || 'Admin' %></div>
        </div>
      </div>
      <button onclick="confirmAction('/admin/logout','POST','Bạn muốn đăng xuất?')" class="btn-logout">Đăng xuất</button>
    </div>
  </header>

  <main class="admin-main">
    <%- body %>
  </main>

  <script>
    window.API_TOKEN = '<%= apiToken || '' %>';
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebarOverlay').classList.toggle('active');
    }
  </script>

  <div id="toasts"></div>
  <div id="confirmOverlay">
    <div class="confirm-box">
      <h4>Xác nhận</h4>
      <p id="confirmMsg">Bạn có chắc muốn thực hiện hành động này?</p>
      <div class="actions"><button class="btn-cancel" onclick="closeConfirm()">Hủy</button><button class="btn-confirm" id="confirmBtn">Xác nhận</button></div>
    </div>
  </div>

  <script>
    function gC(n){var m=document.cookie.match('(^|;)\\s*'+n+'=([^;]*)');return m?decodeURIComponent(m[2]):''}
    function showToast(msg,type){type=type||'info';var c=document.getElementById('toasts');var e=document.createElement('div');e.className='toast '+type;e.innerHTML='<span>'+msg+'</span><button class=close onclick=this.parentElement.remove()>&times;</button>';c.appendChild(e);setTimeout(function(){if(e.parentElement)e.remove()},4000)}
    function confirmAction(url,method,message){document.getElementById('confirmMsg').textContent=message||'Bạn có chắc chắn?';document.getElementById('confirmOverlay').classList.add('active');document.getElementById('confirmBtn').onclick=function(){closeConfirm();var f=document.createElement('form');f.method=method||'POST';f.action=url;f.style.display='none';var csrf=document.createElement('input');csrf.name='_csrf';csrf.value=gC('csrf_token');f.appendChild(csrf);document.body.appendChild(f);f.submit()}}
    function closeConfirm(){document.getElementById('confirmOverlay').classList.remove('active')}
    document.addEventListener('DOMContentLoaded',function(){
      document.querySelectorAll('form[method=POST]').forEach(function(f){if(!f.querySelector('input[name=_csrf]')){var csrf=document.createElement('input');csrf.type='hidden';csrf.name='_csrf';csrf.value=gC('csrf_token');f.appendChild(csrf)}f.addEventListener('submit',function(){var b=f.querySelector('button[type=submit]');if(b){b.disabled=true;b.style.opacity='0.6'}})});
      document.querySelectorAll('[onsubmit*="confirm"]').forEach(function(f){f.onsubmit=function(e){e.preventDefault();var m=(f.getAttribute('onsubmit')||'').match(/confirm\(['\"](.+?)['\"]\)/);confirmAction(f.action,f.method,m?m[1]:'Xác nhận xóa?')}});
      var p=new URLSearchParams(window.location.search);if(p.get('toast'))showToast(decodeURIComponent(p.get('toast')),p.get('type')||'success')
    });
  </script>
  <%- include('admin/partials/ai-chat') %>
  <%# ai-interview-popup removed — now inline in chat panel %>
  <div class="bg-noise"></div>
</body>
</html>

