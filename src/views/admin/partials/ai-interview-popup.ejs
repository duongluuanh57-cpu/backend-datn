<%# AI Interview Popup — Multi-step product creation wizard %>
<div id="aiInterviewOverlay" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:100;align-items:center;justify-content:center;">
  <div id="aiInterviewModal" style="background:var(--bg);border-radius:16px;width:560px;max-width:90vw;max-height:80vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,0.3);">
    <!-- Header -->
    <div style="padding:20px 24px 0;display:flex;justify-content:space-between;align-items:flex-start;">
      <div>
        <h3 id="interviewTitle" style="font-size:16px;font-weight:600;color:var(--text-primary);margin:0 0 4px;"></h3>
        <p id="interviewSubtitle" style="font-size:13px;color:var(--text-muted);margin:0;"></p>
      </div>
      <button onclick="closeInterview()" style="background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:20px;padding:4px;">✕</button>
    </div>

    <!-- Body -->
    <div id="interviewBody" style="padding:20px 24px;min-height:120px;"></div>

    <!-- Footer -->
    <div id="interviewFooter" style="padding:12px 24px 20px;display:flex;gap:10px;flex-wrap:wrap;border-top:1px solid var(--border);">
    </div>
  </div>
</div>

<style>
  .interview-option { display:flex; align-items:center; gap:10px; padding:10px 14px; border:1px solid var(--border); border-radius:10px; cursor:pointer; transition:all 0.15s; margin-bottom:6px; }
  .interview-option:hover { border-color:var(--accent); background:rgba(201,169,110,0.05); }
  .interview-option.selected { border-color:var(--accent); background:rgba(201,169,110,0.1); }
  .interview-option input[type="checkbox"], .interview-option input[type="radio"] { accent-color:var(--accent); width:16px; height:16px; }
  .interview-option .opt-label { font-size:13px; font-weight:500; color:var(--text-primary); }
  .interview-option .opt-desc { font-size:11px; color:var(--text-muted); margin-top:2px; }
  .interview-btn { padding:8px 20px; border-radius:8px; font-size:13px; font-weight:500; cursor:pointer; border:none; transition:all 0.15s; }
  .interview-btn-primary { background:var(--accent); color:#fff; }
  .interview-btn-primary:hover { opacity:0.9; }
  .interview-btn-secondary { background:var(--surface); color:var(--text-primary); border:1px solid var(--border); }
  .interview-btn-secondary:hover { border-color:var(--accent); }
  .interview-btn-skip { background:transparent; color:var(--text-muted); border:1px dashed var(--border); }
  .interview-btn-skip:hover { border-color:var(--accent); color:var(--accent); }
  .interview-btn-danger { background:#fee2e2; color:#dc2626; }
  .interview-btn-danger:hover { background:#fecaca; }
  .interview-input { width:100%; padding:10px 14px; border:1px solid var(--border); border-radius:10px; font-size:14px; font-family:inherit; color:var(--text-primary); background:var(--bg); box-sizing:border-box; }
  .interview-input:focus { outline:none; border-color:var(--accent); box-shadow:0 0 0 2px rgba(201,169,110,0.1); }
  .interview-confirm-item { padding:10px 14px; border:1px solid var(--border); border-radius:10px; margin-bottom:6px; }
  .interview-confirm-item .ci-label { font-size:13px; font-weight:600; color:var(--text-primary); }
  .interview-confirm-item .ci-value { font-size:12px; color:var(--text-muted); margin-top:4px; }
  .interview-tag-grid { display:grid; grid-template-columns:1fr 1fr; gap:6px; }
  .interview-tag-opt { display:flex; align-items:center; gap:8px; padding:8px 12px; border:1px solid var(--border); border-radius:8px; cursor:pointer; font-size:12px; color:var(--text-primary); transition:all 0.15s; }
  .interview-tag-opt:hover { border-color:var(--accent); }
  .interview-tag-opt.selected { border-color:var(--accent); background:rgba(201,169,110,0.1); }
  .interview-tag-opt input { accent-color:var(--accent); }
  .interview-date-row { display:flex; gap:12px; }
  .interview-date-row > div { flex:1; }
  .interview-date-row label { display:block; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; color:var(--text-muted); margin-bottom:4px; }
  .interview-date-row input { width:100%; padding:8px 12px; border:1px solid var(--border); border-radius:8px; font-size:13px; font-family:inherit; color:var(--text-primary); background:var(--bg); box-sizing:border-box; }
  .interview-date-row input:focus { outline:none; border-color:var(--accent); }
  .interview-progress { display:flex; gap:4px; margin-bottom:16px; }
  .interview-progress .dot { width:8px; height:8px; border-radius:50%; background:var(--border); }
  .interview-progress .dot.active { background:var(--accent); }
  .interview-progress .dot.done { background:#16a34a; }
</style>

<script>
var interviewSessionId = null;
var interviewState = null;

function openInterview(sessionId, response) {
  interviewSessionId = sessionId;
  interviewState = response;
  document.getElementById('aiInterviewOverlay').style.display = 'flex';
  renderInterviewStep(response);
  // Block chat input
  var aiInput = document.getElementById('aiInput');
  if (aiInput) { aiInput.disabled = true; aiInput.placeholder = '⏳ Đang trong quá trình tạo sản phẩm...'; }
}

function closeInterview() {
  document.getElementById('aiInterviewOverlay').style.display = 'none';
  interviewSessionId = null;
  interviewState = null;
  var aiInput = document.getElementById('aiInput');
  if (aiInput) { aiInput.disabled = false; aiInput.placeholder = 'Nhập câu hỏi...'; }
}

function renderInterviewStep(res) {
  if (!res) return;
  document.getElementById('interviewTitle').textContent = res.title || '';
  document.getElementById('interviewSubtitle').textContent = res.subtitle || '';
  var body = document.getElementById('interviewBody');
  var footer = document.getElementById('interviewFooter');
  body.innerHTML = '';
  footer.innerHTML = '';

  switch (res.type) {
    case 'select_products':
      renderSelectProducts(body, footer, res);
      break;
    case 'choice_single':
      renderChoiceSingle(body, footer, res);
      break;
    case 'choice_multi':
      renderChoiceMulti(body, footer, res);
      break;
    case 'input_number':
      renderInputNumber(body, footer, res);
      break;
    case 'input_date_range':
      renderInputDateRange(body, footer, res);
      break;
    case 'price_suggestion':
      renderPriceSuggestion(body, footer, res);
      break;
    case 'confirm':
      renderConfirm(body, footer, res);
      break;
    case 'done':
      renderDone(body, footer, res);
      break;
  }
}

// ── Render: Select Products ──
function renderSelectProducts(body, footer, res) {
  var html = '<div class="interview-progress">';
  for (var i = 0; i < res.options.length; i++) html += '<div class="dot"></div>';
  html += '</div>';
  html += '<div style="max-height:300px;overflow-y:auto;">';
  for (var i = 0; i < res.options.length; i++) {
    var opt = res.options[i];
    html += '<div class="interview-option" onclick="toggleSelectProduct(' + i + ')" id="selopt_' + i + '">';
    html += '<input type="checkbox" id="selchk_' + i + '">';
    html += '<div><div class="opt-label">' + escapeHtml(opt.name) + '</div>';
    html += '<div class="opt-desc">' + escapeHtml(opt.description) + '</div></div></div>';
  }
  html += '</div>';
  body.innerHTML = html;

  // Footer buttons
  footer.innerHTML = 
    '<button class="interview-btn interview-btn-skip" onclick="interviewSkipAllProducts()">⚡ Bỏ qua → Chọn tất cả</button>' +
    '<button class="interview-btn interview-btn-primary" onclick="interviewConfirmProducts()" style="margin-left:auto;">✅ Xác nhận</button>';
}

var selectedProducts = [];
function toggleSelectProduct(idx) {
  var chk = document.getElementById('selchk_' + idx);
  var el = document.getElementById('selopt_' + idx);
  chk.checked = !chk.checked;
  el.classList.toggle('selected', chk.checked);
}

function interviewConfirmProducts() {
  selectedProducts = [];
  for (var i = 0; i < interviewState.options.length; i++) {
    var chk = document.getElementById('selchk_' + i);
    if (chk && chk.checked) selectedProducts.push(i);
  }
  if (selectedProducts.length === 0) { alert('Vui lòng chọn ít nhất 1 sản phẩm!'); return; }
  sendInterviewAction({ type: 'select_products', selectedIndices: selectedProducts });
}

function interviewSkipAllProducts() {
  sendInterviewAction({ type: 'skip_all_products' });
}

// ── Render: Choice Single ──
function renderChoiceSingle(body, footer, res) {
  var html = '';
  for (var i = 0; i < res.options.length; i++) {
    var opt = res.options[i];
    html += '<div class="interview-option" onclick="selectSingle(this, \'' + opt.value + '\')" data-value="' + opt.value + '">';
    html += '<input type="radio" name="single_choice" value="' + opt.value + '"' + (opt.value === res.defaultValue ? ' checked' : '') + '>';
    html += '<div><div class="opt-label">' + escapeHtml(opt.label) + '</div>';
    if (opt.description) html += '<div class="opt-desc">' + escapeHtml(opt.description) + '</div>';
    html += '</div></div>';
  }
  body.innerHTML = html;
  // Auto-select default
  var def = body.querySelector('input[value="' + res.defaultValue + '"]');
  if (def) { def.checked = true; def.closest('.interview-option').classList.add('selected'); }

  footer.innerHTML = 
    '<button class="interview-btn interview-btn-secondary" onclick="interviewGoBack()">⬅️ Quay lại</button>' +
    (res.allowSkip ? '<button class="interview-btn interview-btn-skip" onclick="interviewSkipField(\'' + res.field + '\')">Bỏ qua</button>' : '') +
    '<button class="interview-btn interview-btn-primary" onclick="interviewConfirmSingle(\'' + res.field + '\')" style="margin-left:auto;">✅ Xác nhận</button>';
}

function selectSingle(el, value) {
  document.querySelectorAll('#interviewBody .interview-option').forEach(function(e) { e.classList.remove('selected'); });
  el.classList.add('selected');
  el.querySelector('input').checked = true;
}

function interviewConfirmSingle(field) {
  var selected = document.querySelector('#interviewBody input[name="single_choice"]:checked');
  if (!selected) { alert('Vui lòng chọn 1 lựa chọn!'); return; }
  sendInterviewAction({ type: 'product_detail', field: field, value: selected.value });
}

// ── Render: Choice Multi (Tags) ──
function renderChoiceMulti(body, footer, res) {
  var html = '<div class="interview-tag-grid">';
  for (var i = 0; i < res.options.length; i++) {
    var opt = res.options[i];
    html += '<div class="interview-tag-opt" onclick="toggleTag(this, \'' + opt.value + '\')" data-value="' + opt.value + '">';
    html += '<input type="checkbox" value="' + opt.value + '">';
    html += '<span>' + escapeHtml(opt.label) + '</span></div>';
  }
  html += '</div>';
  html += '<div style="margin-top:8px;font-size:11px;color:var(--text-muted);">Đã chọn: <span id="tagCount">0</span>/' + res.maxSelect + '</div>';
  body.innerHTML = html;

  footer.innerHTML = 
    '<button class="interview-btn interview-btn-secondary" onclick="interviewGoBack()">⬅️ Quay lại</button>' +
    (res.allowSkip ? '<button class="interview-btn interview-btn-skip" onclick="interviewSkipField(\'' + res.field + '\')">Bỏ qua</button>' : '') +
    '<button class="interview-btn interview-btn-primary" onclick="interviewConfirmMulti(\'' + res.field + '\')" style="margin-left:auto;">✅ Xác nhận</button>';
}

function toggleTag(el, value) {
  var chk = el.querySelector('input');
  chk.checked = !chk.checked;
  el.classList.toggle('selected', chk.checked);
  var count = document.querySelectorAll('#interviewBody .interview-tag-opt.selected').length;
  var max = interviewState.maxSelect || 4;
  if (count > max) {
    chk.checked = false;
    el.classList.remove('selected');
    alert('Chỉ được chọn tối đa ' + max + ' tag!');
  }
  document.getElementById('tagCount').textContent = Math.min(count, max);
}

function interviewConfirmMulti(field) {
  var selected = [];
  document.querySelectorAll('#interviewBody .interview-tag-opt.selected').forEach(function(el) {
    selected.push(el.getAttribute('data-value'));
  });
  sendInterviewAction({ type: 'product_detail', field: field, value: selected });
}

// ── Render: Input Number ──
function renderInputNumber(body, footer, res) {
  body.innerHTML = '<input type="number" id="numInput" class="interview-input" placeholder="' + escapeHtml(res.placeholder || '') + '" min="0" style="margin-top:8px;">';
  footer.innerHTML = 
    '<button class="interview-btn interview-btn-secondary" onclick="interviewGoBack()">⬅️ Quay lại</button>' +
    (res.allowSkip ? '<button class="interview-btn interview-btn-skip" onclick="interviewSkipField(\'' + res.field + '\')">Bỏ qua</button>' : '') +
    '<button class="interview-btn interview-btn-primary" onclick="interviewConfirmNumber(\'' + res.field + '\')" style="margin-left:auto;">✅ Xác nhận</button>';
}

function interviewConfirmNumber(field) {
  var val = document.getElementById('numInput').value.trim();
  sendInterviewAction({ type: 'product_detail', field: field, value: val || null });
}

// ── Render: Price Suggestion (AI with profit %) ──
function renderPriceSuggestion(body, footer, res) {
  function formatPrice(n) { return (n || 0).toLocaleString('vi-VN'); }
  var html = '<div style="display:flex;flex-direction:column;gap:8px;">';
  for (var i = 0; i < res.options.length; i++) {
    var opt = res.options[i];
    html += '<div class="interview-option" onclick="selectSingle(this, \'' + opt.value + '\')" data-value="' + opt.value + '">';
    html += '<input type="radio" name="single_choice" value="' + opt.value + '"' + (i === 1 ? ' checked' : '') + '>';
    html += '<div style="flex:1;">';
    html += '<div class="opt-label">' + escapeHtml(opt.label) + '</div>';
    html += '<div style="font-size:12px;color:var(--text-primary);font-weight:500;margin:2px 0;">';
    html += formatPrice(opt.price) + '₫</div>';
    html += '<div style="display:flex;gap:12px;font-size:11px;color:var(--text-muted);">';
    html += '<span>💰 Vốn: ' + formatPrice(opt.costPrice) + '₫</span>';
    html += '<span style="color:' + (opt.profitPercent >= 60 ? '#16a34a' : '#ca8a04') + ';font-weight:600;">📈 Lợi nhuận: ' + opt.profitPercent + '%</span>';
    html += '</div>';
    if (opt.description) html += '<div class="opt-desc">' + escapeHtml(opt.description) + '</div>';
    html += '</div></div>';
  }
  html += '</div>';
  body.innerHTML = html;
  // Auto-select middle option (index 1)
  var middle = body.querySelector('input[value="' + res.options[1]?.value + '"]');
  if (middle) { middle.checked = true; middle.closest('.interview-option').classList.add('selected'); }

  footer.innerHTML = 
    '<button class="interview-btn interview-btn-secondary" onclick="interviewGoBack()">⬅️ Quay lại</button>' +
    (res.allowSkip ? '<button class="interview-btn interview-btn-skip" onclick="interviewSkipField(\'' + res.field + '\')">Bỏ qua</button>' : '') +
    '<button class="interview-btn interview-btn-primary" onclick="interviewConfirmSingle(\'' + res.field + '\')" style="margin-left:auto;">✅ Xác nhận</button>';
}

// ── Render: Input Date Range ──
function renderInputDateRange(body, footer, res) {
  var today = new Date().toISOString().slice(0,10);
  body.innerHTML = '<div class="interview-date-row">' +
    '<div><label>Ngày bắt đầu</label><input type="date" id="dateStart" class="interview-input" value="' + today + '"></div>' +
    '<div><label>Ngày kết thúc</label><input type="date" id="dateEnd" class="interview-input" value=""></div>' +
    '</div>';
  footer.innerHTML = 
    '<button class="interview-btn interview-btn-secondary" onclick="interviewGoBack()">⬅️ Quay lại</button>' +
    (res.allowSkip ? '<button class="interview-btn interview-btn-skip" onclick="interviewSkipField(\'' + res.startField + '\')">Bỏ qua</button>' : '') +
    '<button class="interview-btn interview-btn-primary" onclick="interviewConfirmDateRange(\'' + res.startField + '\',\'' + res.endField + '\')" style="margin-left:auto;">✅ Xác nhận</button>';
}

function interviewConfirmDateRange(startField, endField) {
  var start = document.getElementById('dateStart').value;
  var end = document.getElementById('dateEnd').value;
  if (start && end && start > end) { alert('Ngày kết thúc phải sau ngày bắt đầu!'); return; }
  sendInterviewAction({ type: 'product_detail', field: startField, value: start || null });
  // We'll send end date in a follow-up, but for simplicity send both at once
  // Actually we need to send them sequentially. Let's send start first, then end.
  // But the state machine expects one field at a time. Let's handle this differently.
  // For date range, we send start, then the next step will ask for end.
  // Actually the state machine has startField and endField as separate fields.
  // We'll send start now, and the next popup will ask for end.
  // But that's awkward. Let's modify: send both in one action.
  // We'll use a special approach: send startField with value = JSON.stringify({start, end})
  sendInterviewAction({ type: 'product_detail', field: startField, value: JSON.stringify({ start: start, end: end }) });
}

// ── Render: Confirm ──
function renderConfirm(body, footer, res) {
  var html = '';
  for (var i = 0; i < res.items.length; i++) {
    html += '<div class="interview-confirm-item">';
    html += '<div class="ci-label">' + escapeHtml(res.items[i].label) + '</div>';
    html += '<div class="ci-value">' + escapeHtml(res.items[i].value) + '</div></div>';
  }
  body.innerHTML = html;
  footer.innerHTML = 
    '<button class="interview-btn interview-btn-secondary" onclick="interviewGoBack()">⬅️ Quay lại</button>' +
    '<button class="interview-btn interview-btn-primary" onclick="interviewConfirmCreate()" style="margin-left:auto;">🚀 Tiến hành tạo</button>';
}

function interviewConfirmCreate() {
  sendInterviewAction({ type: 'confirm', confirmed: true });
}

// ── Render: Done ──
function renderDone(body, footer, res) {
  body.innerHTML = '<div style="text-align:center;padding:20px;"><div style="font-size:40px;margin-bottom:12px;">🎉</div><p style="font-size:14px;color:var(--text-primary);white-space:pre-line;">' + escapeHtml(res.message) + '</p></div>';
  footer.innerHTML = '<button class="interview-btn interview-btn-primary" onclick="closeInterview()" style="margin-left:auto;">✅ Đóng</button>';
  // Unblock chat
  var aiInput = document.getElementById('aiInput');
  if (aiInput) { aiInput.disabled = false; aiInput.placeholder = 'Nhập câu hỏi...'; }
}

// ── Common Actions ──
function interviewSkipField(field) {
  sendInterviewAction({ type: 'product_detail', field: field, value: null });
}

function interviewGoBack() {
  sendInterviewAction({ type: 'go_back' });
}

// ── Send Action to Server ──
function sendInterviewAction(action) {
  if (!interviewSessionId) return;
  fetch('/api/ai/admin/product-interview', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + (window.API_TOKEN || '') },
    body: JSON.stringify({ sessionId: interviewSessionId, action: action })
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    if (res.error) { alert(res.error); return; }
    interviewSessionId = res.sessionId;
    renderInterviewStep(res.response);
  })
  .catch(function(err) {
    alert('Lỗi kết nối: ' + err.message);
  });
}
</script>