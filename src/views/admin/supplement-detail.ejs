<!-- ═══════════════════════════════════════════════════════════════════════
   Trang Bổ sung thông tin Sản phẩm — Có tương tác upload ảnh, chỉnh sửa
   ═══════════════════════════════════════════════════════════════════════ -->
<div id="supplement-detail">
  <!-- ── Header ── -->
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px;flex-wrap:wrap;">
    <a href="/admin/products/supplement" style="display:inline-flex;align-items:center;gap:6px;color:var(--text-muted);text-decoration:none;font-size:13px;font-weight:500;padding:6px 12px;border-radius:8px;border:1px solid var(--border);" onmouseover="this.style.color='var(--accent)';this.style.borderColor='var(--accent)'" onmouseout="this.style.color='var(--text-muted)';this.style.borderColor='var(--border)'">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Quay lại danh sách chờ
    </a>
    <span style="color:var(--text-muted);">/</span>
    <span id="sd-breadcrumb" style="color:var(--text-primary);font-weight:600;font-size:14px;">Đang tải...</span>
    <span id="sd-status-badge" style="display:none;font-size:11px;padding:3px 12px;border-radius:12px;font-weight:600;"></span>
  </div>

  <!-- ── Loading ── -->
  <div id="sd-loading" style="text-align:center;padding:80px 20px;color:var(--text-muted);">
    <svg style="animation:spin 1s linear infinite;width:28px;height:28px;margin:0 auto 12px;color:var(--accent);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
    Đang tải thông tin sản phẩm...
  </div>

  <!-- ── Error ── -->
  <div id="sd-error" style="display:none;text-align:center;padding:80px 20px;"></div>

  <!-- ── Main Form ── -->
  <div id="sd-form" style="display:none;">
    <form id="supplement-form" onsubmit="event.preventDefault();">
      
      <!-- ── 2-Column Layout ── -->
      <div style="display:grid;grid-template-columns:300px 1fr;gap:24px;align-items:start;">
        
        <!-- ── LEFT: Ảnh ── -->
        <div class="dt-card" style="position:sticky;top:80px;">
          <h3 style="font-size:14px;font-weight:600;margin:0 0 12px;color:var(--text-primary);display:flex;align-items:center;gap:8px;">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            Ảnh sản phẩm
          </h3>
          
          <!-- Main image preview -->
          <div style="font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:6px;">Ảnh chính</div>
          <div id="sd-image-preview" style="width:100%;aspect-ratio:1;border-radius:12px;overflow:hidden;border:2px solid var(--accent);background:var(--bg);margin-bottom:8px;display:flex;align-items:center;justify-content:center;">
            <span style="color:var(--text-muted);font-size:12px;">Chưa có ảnh</span>
          </div>
          
          <!-- Upload main image button -->
          <input type="file" id="sd-image-upload" accept="image/*" style="display:none;" onchange="handleImageUpload(event, null)" />
          <button type="button" onclick="document.getElementById('sd-image-upload').click()" style="width:100%;display:flex;align-items:center;justify-content:center;gap:6px;padding:10px;border:2px dashed var(--accent);border-radius:10px;background:rgba(201,169,110,0.04);color:var(--accent);cursor:pointer;font-size:13px;font-weight:600;transition:all 0.2s;margin-bottom:16px;" onmouseover="this.style.background='rgba(201,169,110,0.1)'" onmouseout="this.style.background='rgba(201,169,110,0.04)'">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            Tải ảnh chính
          </button>

          <!-- Sub images -->
          <div style="font-size:11px;font-weight:600;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px;">Ảnh phụ</div>
          <div id="sd-sub-images" style="display:flex;flex-direction:column;gap:8px;">
            <!-- sub image rows injected by JS -->
          </div>
          <button type="button" onclick="addSubImage()" style="width:100%;display:flex;align-items:center;justify-content:center;gap:4px;padding:8px;border:1px dashed var(--border);border-radius:8px;background:var(--bg);color:var(--text-muted);cursor:pointer;font-size:12px;font-weight:500;transition:all 0.2s;margin-top:8px;" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Thêm ảnh phụ
          </button>
          <div id="sd-upload-status" style="margin-top:8px;font-size:11px;color:var(--text-muted);text-align:center;"></div>
        </div>

        <!-- ── RIGHT: Thông tin ── -->
        <div style="display:flex;flex-direction:column;gap:20px;">
          
          <!-- ── Card: Thông tin cơ bản ── -->
          <div class="dt-card">
            <h3 style="font-size:14px;font-weight:600;margin:0 0 16px;color:var(--text-primary);">Thông tin cơ bản</h3>
            
            <div style="display:flex;flex-direction:column;gap:12px;">
              <!-- Tên sản phẩm -->
              <div class="supp-form-group">
                <label>Tên sản phẩm</label>
                <input type="text" id="sd-name" placeholder="Nhập tên sản phẩm" />
              </div>

              <!-- Thương hiệu -->
              <div class="supp-form-group">
                <label>Thương hiệu</label>
                <select id="sd-brand">
                  <option value="">-- Chọn thương hiệu --</option>
                </select>
              </div>

              <!-- Danh mục -->
              <div class="supp-form-group">
                <label>Danh mục (chọn tối thiểu 2)</label>
                <div id="sd-categories" style="display:flex;flex-wrap:wrap;gap:8px;">
                  <!-- checkboxes injected by JS -->
                </div>
              </div>

              <!-- Mô tả -->
              <div class="supp-form-group">
                <label>Mô tả <span style="font-weight:400;color:var(--text-muted);">(AI đã tạo sẵn)</span></label>
                <textarea id="sd-description" rows="5" placeholder="Mô tả sản phẩm do AI tạo"></textarea>
              </div>
            </div>
          </div>

          <!-- ── Card: Biến thể (Variants) ── -->
          <div class="dt-card">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
              <h3 style="font-size:14px;font-weight:600;margin:0;color:var(--text-primary);">Biến thể</h3>
              <button type="button" onclick="addVariant()" style="display:flex;align-items:center;gap:4px;padding:6px 14px;border:1px solid var(--accent);border-radius:8px;background:transparent;color:var(--accent);cursor:pointer;font-size:12px;font-weight:600;transition:all 0.2s;" onmouseover="this.style.background='rgba(201,169,110,0.08)'" onmouseout="this.style.background='transparent'">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Thêm biến thể
              </button>
            </div>
            <div id="sd-variants-list" style="display:flex;flex-direction:column;gap:8px;">
              <!-- variant rows injected by JS -->
            </div>
          </div>

          <!-- ── Card: Thuộc tính nước hoa (read-only preview) ── -->
          <div class="dt-card">
            <h3 style="font-size:14px;font-weight:600;margin:0 0 12px;color:var(--text-primary);display:flex;align-items:center;gap:8px;">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="var(--accent)" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              Thuộc tính AI đã phân tích
              <span style="font-size:11px;color:var(--text-muted);font-weight:400;">(read-only)</span>
            </h3>
            <div id="sd-scent-meta" style="display:grid;grid-template-columns:repeat(auto-fill, minmax(220px, 1fr));gap:8px;">
              <!-- scent meta injected by JS -->
            </div>
          </div>

          <!-- ── Actions ── -->
          <div style="display:flex;gap:12px;align-items:center;flex-wrap:wrap;">
            <button type="button" id="sd-btn-draft" onclick="saveProduct(false)" style="display:flex;align-items:center;gap:6px;padding:10px 24px;border:1px solid var(--border);border-radius:10px;background:var(--surface);color:var(--text-primary);cursor:pointer;font-size:13px;font-weight:600;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--accent)';this.style.color='var(--accent)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-primary)'">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
              Lưu tạm
            </button>
            <button type="button" id="sd-btn-activate" onclick="saveProduct(true)" style="display:flex;align-items:center;gap:6px;padding:10px 24px;border:none;border-radius:10px;background:var(--accent);color:#fff;cursor:pointer;font-size:13px;font-weight:600;transition:all 0.2s;box-shadow:0 2px 8px rgba(201,169,110,0.25);" onmouseover="this.style.filter='brightness(1.1)';this.style.boxShadow='0 4px 16px rgba(201,169,110,0.35)'" onmouseout="this.style.filter='';this.style.boxShadow='0 2px 8px rgba(201,169,110,0.25)'">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              Lưu & Kích hoạt
            </button>
            <span id="sd-save-status" style="font-size:12px;"></span>
          </div>
        </div>
      </div>
    </form>
  </div>
</div>

<style>
  #sd-image-preview img { width:100%; height:100%; object-fit:cover; }
  .supp-form-group { display:flex; flex-direction:column; gap:4px; }
  .supp-form-group label { font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; color:var(--text-muted); }
  .supp-form-group input,
  .supp-form-group textarea,
  .supp-form-group select {
    padding:8px 12px; border:1px solid var(--border); border-radius:8px; font-size:13px; font-family:inherit; color:var(--text-primary); background:var(--bg); resize:vertical;
  }
  .supp-form-group input:focus,
  .supp-form-group textarea:focus,
  .supp-form-group select:focus { outline:none; border-color:var(--accent); box-shadow:0 0 0 2px rgba(201,169,110,0.1); }
  
  .variant-row {
    display:flex; gap:8px; align-items:center; padding:8px; background:var(--bg); border-radius:8px; border:1px solid var(--border);
  }
  .variant-row input { padding:6px 10px; border:1px solid var(--border); border-radius:6px; font-size:12px; font-family:inherit; color:var(--text-primary); background:var(--surface); }
  .variant-row input:focus { outline:none; border-color:var(--accent); }
  .variant-row .v-size { width:80px; }
  .variant-row .v-price { width:100px; }
  .variant-row .v-stock { width:70px; }
  .variant-row .v-default { width:20px; height:20px; accent-color:var(--accent); cursor:pointer; }
  
  .scent-meta-item {
    display:flex; align-items:center; gap:8px; padding:8px 12px; background:var(--bg); border-radius:8px; border:1px solid var(--border);
  }
  .scent-meta-icon { width:16px; height:16px; color:var(--accent); flex-shrink:0; }
  .scent-meta-icon svg { width:100%; height:100%; }
  .scent-meta-label { font-size:10px; color:var(--text-muted); min-width:80px; text-transform:uppercase; letter-spacing:0.5px; }
  .scent-meta-value { font-size:12px; font-weight:500; color:var(--text-primary); }
  
  @keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
  
  @media (max-width:768px) {
    #supplement-detail > div > div:first-child { grid-template-columns:1fr; }
    .variant-row { flex-wrap:wrap; }
  }
</style>

<script>
var PRODUCT_ID = '<%= productId %>';
var TOKEN = '<%= apiToken %>';
var TENANT = '<%= tenantId || 'default' %>';
var H = { 'Authorization': 'Bearer ' + TOKEN, 'Content-Type': 'application/json' };
var currentProduct = null;
var allBrands = [];
var allCategories = [];
var currentVariants = [];
var subImageCount = 0;
var uploadedSubImages = []; // [{ index, url }]

function $(id) { return document.getElementById(id); }
function fmt(n) { return (n || 0).toLocaleString('vi-VN'); }
function fmtCurrency(n) { return fmt(n) + 'đ'; }
function escapeHtml(str) {
  if (!str) return '';
  return String(str).replace(/[&<>"']/g, function(m){ return {'&':'&','<':'<','>':'>','"':'"',"'":'&#39;'}[m]||m; });
}

// ═══════════════════════════════════════════════════════════════
// LOAD DATA
// ═══════════════════════════════════════════════════════════════
Promise.all([
  fetch('/api/products/' + PRODUCT_ID + '?tenantId=' + TENANT, { headers: H }).then(function(r) { return r.json(); }),
  fetch('/api/brands', { headers: H }).then(function(r) { return r.json(); }).catch(function(){ return { success:false, data:[] }; }),
  fetch('/api/categories', { headers: H }).then(function(r) { return r.json(); }).catch(function(){ return { success:false, data:[] }; }),
]).then(function(results) {
  var productRes = results[0];
  var brandsRes = results[1];
  var categoriesRes = results[2];

  if (!productRes.success || !productRes.data) {
    $('sd-loading').style.display = 'none';
    $('sd-error').style.display = 'block';
    $('sd-error').innerHTML = '<p style="font-size:16px;font-weight:600;color:var(--danger);">Không tìm thấy sản phẩm</p><p style="margin-top:8px;font-size:13px;color:var(--text-muted);">Sản phẩm có thể đã bị xóa.</p>';
    return;
  }

  currentProduct = productRes.data;
  allBrands = brandsRes.success ? (brandsRes.data || []) : [];
  allCategories = categoriesRes.success ? (categoriesRes.data || []) : [];

  renderForm();
  $('sd-loading').style.display = 'none';
  $('sd-form').style.display = 'block';
}).catch(function() {
  $('sd-loading').style.display = 'none';
  $('sd-error').style.display = 'block';
  $('sd-error').innerHTML = '<p style="font-size:16px;font-weight:600;color:var(--danger);">Lỗi kết nối</p>';
});

// ═══════════════════════════════════════════════════════════════
// RENDER FORM
// ═══════════════════════════════════════════════════════════════
function renderForm() {
  var p = currentProduct;
  $('sd-breadcrumb').textContent = (p.brand || '') + ' · ' + (p.name || '');
  document.title = 'Bổ sung: ' + (p.name || 'Sản phẩm') + ' — Admin';

  // Status badge
  var badge = $('sd-status-badge');
  if (p.status === 'draft') {
    badge.style.display = 'inline-block';
    badge.style.background = 'rgba(245,158,11,0.12)';
    badge.style.color = '#d97706';
    badge.textContent = '⏳ Chờ bổ sung';
  } else if (p.status === 'active') {
    badge.style.display = 'inline-block';
    badge.style.background = 'rgba(34,197,94,0.12)';
    badge.style.color = '#16a34a';
    badge.textContent = '✓ Đã kích hoạt';
  }

  // Product image
  if (p.image) {
    $('sd-image-preview').innerHTML = '<img src="' + escapeHtml(p.image) + '" alt="" />';
  }

  // Name
  $('sd-name').value = p.name || '';

  // Description
  $('sd-description').value = p.description || '';

  // Brands dropdown
  var brandHtml = '<option value="">-- Chọn thương hiệu --</option>';
  allBrands.forEach(function(b) {
    var selected = (p.brand && p.brand === b.name) || (p.brandId && (p.brandId._id || p.brandId) === b._id) ? ' selected' : '';
    brandHtml += '<option value="' + b._id + '"' + selected + '>' + escapeHtml(b.name) + '</option>';
  });
  $('sd-brand').innerHTML = brandHtml;

  // Categories checkboxes
  var currentCatIds = Array.isArray(p.categories) ? p.categories.map(function(c) { return typeof c === 'string' ? c : c._id; }) : [];
  var catCheckboxes = '';
  allCategories.forEach(function(c) {
    var checked = currentCatIds.indexOf(c._id) !== -1 ? ' checked' : '';
    catCheckboxes += '<label style="display:flex;align-items:center;gap:6px;font-size:12px;cursor:pointer;padding:4px 10px;border:1px solid var(--border);border-radius:20px;background:' + (checked ? 'rgba(201,169,110,0.08)' : 'var(--surface)') + ';">' +
      '<input type="checkbox" value="' + c._id + '"' + checked + ' onchange="this.parentElement.style.background=this.checked?\'rgba(201,169,110,0.08)\':\'var(--surface)\'" style="accent-color:var(--accent);" />' +
      escapeHtml(c.name) +
    '</label>';
  });
  $('sd-categories').innerHTML = catCheckboxes || '<span style="color:var(--text-muted);font-size:12px;">Chưa có danh mục nào</span>';

  // Variants
  var variants = Array.isArray(p.variants) ? p.variants : [];
  currentVariants = variants.map(function(v) {
    return { size: v.size || '', price: v.price || 0, quantityInStock: v.quantityInStock || 0, isDefault: v.isDefault || false, _id: v._id || null };
  });
  if (currentVariants.length === 0) {
    currentVariants.push({ size: '50ml', price: 0, quantityInStock: 0, isDefault: true, _id: null });
  }
  renderVariants();

  // Scent metadata (read-only preview)
  var scentMeta = [
    { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>', label: 'Độ lưu hương', value: p.longevity },
    { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>', label: 'Độ tỏa hương', value: p.sillage },
    { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20V10M18 20V4M6 20v-4"/></svg>', label: 'Độ bền', value: p.durability },
    { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>', label: 'Hương đặc trưng', value: p.scentTrail },
    { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>', label: 'Phong cách', value: p.style },
    { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>', label: 'Phù hợp', value: p.suitableFor },
    { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>', label: 'Dịp', value: p.occasion },
    { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>', label: 'Mùa', value: p.season },
    { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/></svg>', label: 'Thời điểm', value: p.time },
  ];
  var scentHtml = '';
  scentMeta.forEach(function(m) {
    scentHtml += '<div class="scent-meta-item">' +
      '<span class="scent-meta-icon">' + m.icon + '</span>' +
      '<span class="scent-meta-label">' + m.label + '</span>' +
      '<span class="scent-meta-value">' + escapeHtml(m.value || '—') + '</span>' +
    '</div>';
  });
  $('sd-scent-meta').innerHTML = scentHtml || '<span style="color:var(--text-muted);font-size:12px;">Chưa có thuộc tính</span>';
}

// ═══════════════════════════════════════════════════════════════
// VARIANTS
// ═══════════════════════════════════════════════════════════════
function renderVariants() {
  var html = '';
  currentVariants.forEach(function(v, i) {
    html += '<div class="variant-row">' +
      '<input type="text" class="v-size" value="' + escapeHtml(v.size) + '" placeholder="Size" onchange="updateVariant(' + i + ', \'size\', this.value)" />' +
      '<input type="number" class="v-price" value="' + v.price + '" placeholder="Giá" min="0" onchange="updateVariant(' + i + ', \'price\', Number(this.value))" />' +
      '<input type="number" class="v-stock" value="' + v.quantityInStock + '" placeholder="Tồn kho" min="0" onchange="updateVariant(' + i + ', \'quantityInStock\', Number(this.value))" />' +
      '<label style="display:flex;align-items:center;gap:4px;font-size:11px;color:var(--text-muted);cursor:pointer;white-space:nowrap;">' +
        '<input type="radio" name="v-default" class="v-default"' + (v.isDefault ? ' checked' : '') + ' onchange="setDefaultVariant(' + i + ')" /> Mặc định' +
      '</label>' +
      '<button type="button" onclick="removeVariant(' + i + ')" style="padding:4px 8px;border:none;background:transparent;color:var(--danger);cursor:pointer;font-size:16px;line-height:1;" title="Xóa biến thể">&times;</button>' +
    '</div>';
  });
  $('sd-variants-list').innerHTML = html || '<span style="color:var(--text-muted);font-size:12px;padding:8px;">Chưa có biến thể</span>';
}

function addVariant() {
  currentVariants.push({ size: '', price: 0, quantityInStock: 0, isDefault: currentVariants.length === 0, _id: null });
  renderVariants();
}

function removeVariant(index) {
  if (currentVariants.length <= 1) return;
  var wasDefault = currentVariants[index].isDefault;
  currentVariants.splice(index, 1);
  if (wasDefault && currentVariants.length > 0) currentVariants[0].isDefault = true;
  renderVariants();
}

function updateVariant(index, field, value) {
  currentVariants[index][field] = value;
}

function setDefaultVariant(index) {
  currentVariants.forEach(function(v, i) { v.isDefault = i === index; });
}

// ═══════════════════════════════════════════════════════════════
// IMAGE UPLOAD (dùng pipeline sharpen + upscale cho sản phẩm)
// ═══════════════════════════════════════════════════════════════
function getProductSlug() {
  var name = $('sd-name').value.trim() || currentProduct.name || 'product';
  return name
    .replace(/[^a-zA-Z0-9\u00C0-\u1EF9\-]/g, '-')
    .toLowerCase()
    .replace(/-+/g, '-')
    .replace(/^-|-$/g, '') || 'product';
}

function handleImageUpload(event, subIndex) {
  var file = event.target.files[0];
  if (!file) return;

  var statusEl = $('sd-upload-status');
  statusEl.textContent = 'Đang tải ảnh lên...';
  statusEl.style.color = 'var(--accent)';

  var slug = getProductSlug();
  var formData = new FormData();
  formData.append('image', file);
  formData.append('productSlug', slug);
  if (subIndex !== null && subIndex !== undefined) {
    formData.append('subIndex', String(subIndex));
  }

  var queryStr = '?productSlug=' + encodeURIComponent(slug);
  if (subIndex !== null && subIndex !== undefined) {
    queryStr += '&subIndex=' + subIndex;
  }

  fetch('/api/media/upload-r2' + queryStr, {
    method: 'POST',
    headers: { 'Authorization': 'Bearer ' + TOKEN },
    body: formData,
  })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (res.success && res.data && res.data.url) {
        if (subIndex === null || subIndex === undefined) {
          // Main image
          $('sd-image-preview').innerHTML = '<img src="' + res.data.url + '" alt="" />';
          currentProduct._uploadedImage = res.data.url;
          statusEl.textContent = '✓ Ảnh chính đã tải lên (sharpen + upscale)';
        } else {
          // Sub image
          uploadedSubImages.push({ index: subIndex, url: res.data.url });
          statusEl.textContent = '✓ Ảnh phụ #' + (subIndex + 1) + ' đã tải lên (sharpen + upscale)';
          renderSubImages();
        }
        statusEl.style.color = '#16a34a';
      } else {
        statusEl.textContent = 'Lỗi: ' + (res.message || 'Không thể upload');
        statusEl.style.color = 'var(--danger)';
      }
    })
    .catch(function() {
      statusEl.textContent = 'Lỗi kết nối khi upload';
      statusEl.style.color = 'var(--danger)';
    });

  // Reset input
  event.target.value = '';
}

// ── Sub images management ──
function addSubImage() {
  subImageCount++;
  var idx = subImageCount - 1;

  var inputId = 'sd-sub-upload-' + idx;
  var row = document.createElement('div');
  row.id = 'sd-sub-row-' + idx;
  row.style.cssText = 'display:flex;align-items:center;gap:8px;padding:8px;background:var(--bg);border-radius:8px;border:1px solid var(--border);';

  // Preview placeholder
  var preview = document.createElement('div');
  preview.id = 'sd-sub-preview-' + idx;
  preview.style.cssText = 'width:48px;height:48px;border-radius:6px;overflow:hidden;border:1px solid var(--border);background:var(--surface);flex-shrink:0;display:flex;align-items:center;justify-content:center;';
  preview.innerHTML = '<span style="font-size:10px;color:var(--text-muted);">#' + (idx+1) + '</span>';

  // File input
  var fileInput = document.createElement('input');
  fileInput.type = 'file';
  fileInput.id = inputId;
  fileInput.accept = 'image/*';
  fileInput.style.display = 'none';
  fileInput.onchange = function(e) {
    handleImageUpload(e, idx);
    // Show preview immediately
    var f = e.target.files[0];
    if (f) {
      var reader = new FileReader();
      reader.onload = function(ev) {
        document.getElementById('sd-sub-preview-' + idx).innerHTML = '<img src="' + ev.target.result + '" alt="" style="width:100%;height:100%;object-fit:cover;" />';
      };
      reader.readAsDataURL(f);
    }
  };

  // Upload button
  var btn = document.createElement('button');
  btn.type = 'button';
  btn.textContent = 'Chọn ảnh #' + (idx+1);
  btn.style.cssText = 'flex:1;padding:6px 12px;border:1px dashed var(--border);border-radius:6px;background:transparent;color:var(--text-muted);cursor:pointer;font-size:12px;text-align:left;';
  btn.onclick = function() { document.getElementById(inputId).click(); };

  // Remove button
  var removeBtn = document.createElement('button');
  removeBtn.type = 'button';
  removeBtn.innerHTML = '&times;';
  removeBtn.style.cssText = 'padding:4px 8px;border:none;background:transparent;color:var(--danger);cursor:pointer;font-size:16px;line-height:1;';
  removeBtn.onclick = function() {
    // Remove uploaded image if any
    uploadedSubImages = uploadedSubImages.filter(function(si) { return si.index !== idx; });
    document.getElementById('sd-sub-row-' + idx).remove();
  };

  row.appendChild(preview);
  row.appendChild(fileInput);
  row.appendChild(btn);
  row.appendChild(removeBtn);

  $('sd-sub-images').appendChild(row);
}

function renderSubImages() {
  // Update previews for already-uploaded sub images
  uploadedSubImages.forEach(function(si) {
    var preview = document.getElementById('sd-sub-preview-' + si.index);
    if (preview) {
      preview.innerHTML = '<img src="' + si.url + '" alt="" style="width:100%;height:100%;object-fit:cover;" />';
    }
  });
}

// ═══════════════════════════════════════════════════════════════
// SAVE
// ═══════════════════════════════════════════════════════════════
function saveProduct(activate) {
  var statusEl = $('sd-save-status');
  statusEl.textContent = 'Đang lưu...';
  statusEl.style.color = 'var(--accent)';

  var btnDraft = $('sd-btn-draft');
  var btnActivate = $('sd-btn-activate');
  btnDraft.disabled = true;
  btnActivate.disabled = true;
  btnDraft.style.opacity = '0.6';
  btnActivate.style.opacity = '0.6';

  // Gather data
  var selectedCategories = [];
  var checkboxes = document.querySelectorAll('#sd-categories input[type="checkbox"]:checked');
  checkboxes.forEach(function(cb) { selectedCategories.push(cb.value); });

  var body = {
    name: $('sd-name').value.trim(),
    description: $('sd-description').value.trim(),
    brandId: $('sd-brand').value || undefined,
    categories: selectedCategories,
    variants: currentVariants,
    isSupplemented: activate,
    status: activate ? 'active' : 'draft',
  };

  // If a new main image was uploaded, use it
  if (currentProduct._uploadedImage) {
    body.image = currentProduct._uploadedImage;
  }
  // Add sub images
  if (uploadedSubImages.length > 0) {
    body.images = uploadedSubImages.map(function(si) { return si.url; });
  }

  // PATCH to update
  fetch('/api/products/' + PRODUCT_ID, {
    method: 'PATCH',
    headers: H,
    body: JSON.stringify(body),
  })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (res.success) {
        if (res.autoActivated || activate) {
          statusEl.textContent = '✅ Sản phẩm đã được kích hoạt! Đang chuyển trang...';
          statusEl.style.color = '#16a34a';
          setTimeout(function() {
            window.location.href = '/admin/products/supplement?toast=Đã+kích+hoạt+sản+phẩm&type=success';
          }, 1200);
        } else {
          statusEl.textContent = '✓ Đã lưu bản nháp';
          statusEl.style.color = '#16a34a';
          setTimeout(function() { statusEl.textContent = ''; }, 3000);
        }
      } else {
        statusEl.textContent = 'Lỗi: ' + (res.message || 'Không thể lưu');
        statusEl.style.color = 'var(--danger)';
      }
      btnDraft.disabled = false;
      btnActivate.disabled = false;
      btnDraft.style.opacity = '1';
      btnActivate.style.opacity = '1';
    })
    .catch(function() {
      statusEl.textContent = 'Lỗi kết nối';
      statusEl.style.color = 'var(--danger)';
      btnDraft.disabled = false;
      btnActivate.disabled = false;
      btnDraft.style.opacity = '1';
      btnActivate.style.opacity = '1';
    });
}
</script>