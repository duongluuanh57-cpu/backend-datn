<%# Settings Page %>
<div class="stat-grid" style="grid-template-columns:1fr 1fr;gap:24px;">
  <div class="stat-card" style="flex-direction:column;align-items:stretch;padding:24px;">
    <h3 style="font-size:16px;font-weight:600;margin-bottom:20px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:18px;height:18px;vertical-align:middle;margin-right:6px;"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg> Cài đặt chung</h3>
    <form method="POST" action="/admin/settings">
      <div style="display:flex;flex-direction:column;gap:16px;">
        <div>
          <label style="display:block;font-size:13px;color:var(--text-muted);margin-bottom:4px;">Tên cửa hàng</label>
          <input name="shopName" value="<%= shopName || 'L\'essence' %>" style="background:var(--bg-darker);border:1px solid var(--border);border-radius:8px;padding:10px;color:var(--text-primary);width:100%;font-size:14px;">
        </div>
        <div>
          <label style="display:block;font-size:13px;color:var(--text-muted);margin-bottom:4px;">Email liên hệ</label>
          <input name="shopEmail" value="<%= shopEmail || '' %>" style="background:var(--bg-darker);border:1px solid var(--border);border-radius:8px;padding:10px;color:var(--text-primary);width:100%;font-size:14px;">
        </div>
        <div>
          <label style="display:block;font-size:13px;color:var(--text-muted);margin-bottom:4px;">Số điện thoại</label>
          <input name="shopPhone" value="<%= shopPhone || '' %>" style="background:var(--bg-darker);border:1px solid var(--border);border-radius:8px;padding:10px;color:var(--text-primary);width:100%;font-size:14px;">
        </div>
        <div>
          <label style="display:block;font-size:13px;color:var(--text-muted);margin-bottom:4px;">Địa chỉ</label>
          <input name="shopAddress" value="<%= shopAddress || '' %>" style="background:var(--bg-darker);border:1px solid var(--border);border-radius:8px;padding:10px;color:var(--text-primary);width:100%;font-size:14px;">
        </div>
        <button type="submit" class="admin-btn admin-btn-primary" style="margin-top:8px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:18px;height:18px;vertical-align:middle;margin-right:4px;"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Lưu cài đặt</button>
      </div>
    </form>
    <% if (typeof saved !== 'undefined' && saved) { %>
      <div style="margin-top:12px;padding:10px;background:rgba(34,197,94,0.15);border-radius:8px;color:#22c55e;font-size:13px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:18px;height:18px;vertical-align:middle;margin-right:4px;"><polyline points="20 6 9 17 4 12"/></svg> Đã lưu thành công!</div>
    <% } %>
  </div>

  <div class="stat-card" style="flex-direction:column;align-items:stretch;padding:24px;">
    <h3 style="font-size:16px;font-weight:600;margin-bottom:20px;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:18px;height:18px;vertical-align:middle;margin-right:6px;"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg> Thông tin hệ thống</h3>
    <div style="display:flex;flex-direction:column;gap:12px;">
      <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);"><span style="color:var(--text-muted);">Môi trường</span><span><%= env || 'development' %></span></div>
      <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);"><span style="color:var(--text-muted);">Database</span><span style="color:#22c55e;">Connected</span></div>
      <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);"><span style="color:var(--text-muted);">Redis</span><span style="color:#22c55e;">Connected</span></div>
      <div style="display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border);"><span style="color:var(--text-muted);">Node.js</span><span><%= nodeVersion || 'v22' %></span></div>
      <div style="display:flex;justify-content:space-between;padding:8px 0;"><span style="color:var(--text-muted);">Server time</span><span><%= serverTime || '' %></span></div>
    </div>
  </div>
</div>
