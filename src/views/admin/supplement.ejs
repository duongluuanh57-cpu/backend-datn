<!-- ─── Trang Bổ sung thông tin sản phẩm ─── -->
<div id="supplement-app">
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;flex-wrap:wrap;">
    <a href="/admin/products" style="display:inline-flex;align-items:center;gap:6px;color:var(--text-muted);text-decoration:none;font-size:13px;font-weight:500;padding:6px 12px;border-radius:8px;border:1px solid var(--border);" onmouseover="this.style.color='var(--accent)';this.style.borderColor='var(--accent)'" onmouseout="this.style.color='var(--text-muted)';this.style.borderColor='var(--border)'">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Quay lại Sản phẩm
    </a>
    <h2 style="font-size:18px;font-weight:600;color:var(--text-primary);margin:0;">Bổ sung thông tin sản phẩm</h2>
    <span id="supp-count" style="background:var(--accent);color:#fff;border-radius:20px;padding:2px 12px;font-size:12px;font-weight:600;">—</span>
  </div>

  <p style="color:var(--text-muted);font-size:13px;margin-bottom:20px;">
    Các sản phẩm dưới đây được tạo bởi AI và đang thiếu thông tin. 
    <strong>Scroll chuột lên ↑ để chuyển sang phải, scroll xuống ↓ để chuyển sang trái.</strong>
    Click vào một card để bổ sung thông tin.
  </p>

  <!-- ── Loading ── -->
  <div id="supp-loading" style="text-align:center;padding:60px;color:var(--text-muted);">
    <svg style="animation:spin 1s linear infinite;width:28px;height:28px;margin:0 auto 12px;color:var(--accent);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
    Đang tải danh sách sản phẩm cần bổ sung...
  </div>

  <!-- ── Empty state ── -->
  <div id="supp-empty" style="display:none;text-align:center;padding:80px 20px;">
    <svg viewBox="0 0 24 24" width="64" height="64" fill="none" stroke="var(--accent)" stroke-width="1" style="margin:0 auto 16px;opacity:0.6;"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
    <p style="font-size:15px;font-weight:600;color:var(--text-primary);margin:0 0 6px;">Không có sản phẩm nào cần bổ sung! 🎉</p>
    <p style="color:var(--text-muted);font-size:13px;">Tất cả sản phẩm đã được hoàn thiện đầy đủ thông tin.</p>
  </div>

  <!-- ── Horizontal scroll container ── -->
  <div id="supp-cards-wrap" style="display:none;position:relative;margin-bottom:24px;">
    <div id="supp-cards" style="display:flex;gap:16px;overflow-x:auto;overflow-y:hidden;padding:8px 4px 16px;scroll-behavior:smooth;scrollbar-width:thin;scrollbar-color:var(--border) transparent;">
      <!-- cards injected by JS -->
    </div>
  </div>

</div>

<style>
  #supp-cards::-webkit-scrollbar { height: 6px; }
  #supp-cards::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
  #supp-cards::-webkit-scrollbar-track { background: transparent; }

  .supp-card {
    flex: 0 0 220px;
    height: 320px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.25s ease;
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .supp-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(201,169,110,0.12);
    border-color: var(--accent);
  }
  .supp-card.selected {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px var(--accent);
  }

  .supp-card-img {
    width: 100%;
    height: 150px;
    object-fit: cover;
    background: var(--bg, #f5f5f5);
    flex-shrink: 0;
  }
  .supp-card-img-placeholder {
    width: 100%;
    height: 150px;
    background: linear-gradient(135deg, rgba(201,169,110,0.08), rgba(201,169,110,0.02));
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    flex-shrink: 0;
  }

  .supp-card-body {
    padding: 12px 14px 8px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .supp-card-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 4px;
  }
  .supp-card-brand {
    font-size: 11px;
    color: var(--text-muted);
    margin-bottom: 8px;
  }
  .supp-card-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: auto;
  }
  .supp-badge {
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 10px;
    font-weight: 500;
  }
  .supp-badge.missing {
    background: rgba(245,158,11,0.12);
    color: #d97706;
  }
  .supp-badge.done {
    background: rgba(34,197,94,0.12);
    color: #16a34a;
  }

  .supp-form-group {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .supp-form-group label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--text-muted);
  }
  .supp-form-group input,
  .supp-form-group textarea,
  .supp-form-group select {
    padding: 8px 12px;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 13px;
    font-family: inherit;
    color: var(--text-primary);
    background: var(--bg);
    resize: vertical;
  }

  @keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }

  @media (max-width: 768px) {
    #supp-detail-form { grid-template-columns: 1fr; }
    .supp-card { flex: 0 0 180px; height: 280px; }
  }
</style>

<script>
var TOKEN = '<%= apiToken %>';
var TENANT = '<%= tenantId %>';
var H = { 'Authorization': 'Bearer ' + TOKEN, 'Content-Type': 'application/json' };
var currentProducts = [];
var selectedProductId = null;

function $(id) { return document.getElementById(id); }
function fmt(n) { return (n || 0).toLocaleString('vi-VN'); }
function fmtCurrency(n) { return fmt(n) + 'đ'; }
function escapeHtml(str) {
  if (!str) return '';
  return String(str).replace(/[&<>"']/g, function(m){ return {'&':'&','<':'<','>':'>','"':'"',"'":'&#39;'}[m]||m; });
}

// ── Fetch products needing supplement ──
function loadSupplementProducts() {
  fetch('/api/products/needs-supplement', { headers: H })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (!res.success) {
        $('supp-loading').innerHTML = '<p style="color:var(--danger);">Lỗi tải dữ liệu: ' + escapeHtml(res.message) + '</p>';
        return;
      }
      currentProducts = res.data || [];
      $('supp-count').textContent = currentProducts.length + ' sản phẩm';

      if (currentProducts.length === 0) {
        $('supp-loading').style.display = 'none';
        $('supp-empty').style.display = 'block';
        $('supp-cards-wrap').style.display = 'none';
        // Update sidebar badge
        updateSidebarBadge(0);
        return;
      }

      $('supp-loading').style.display = 'none';
      $('supp-empty').style.display = 'none';
      $('supp-cards-wrap').style.display = 'block';

      renderCards();
      updateSidebarBadge(currentProducts.length);
    })
    .catch(function() {
      $('supp-loading').innerHTML = '<p style="color:var(--danger);">Lỗi kết nối đến server</p>';
    });
}

// ── Render horizontal cards ──
function renderCards() {
  var container = $('supp-cards');
  var html = '';
  currentProducts.forEach(function(p) {
    var badgesHtml = '';
    if (p.missing && p.missing.length > 0) {
      badgesHtml = p.missing.map(function(m) {
        var labels = { description: 'Thiếu mô tả', image: 'Thiếu ảnh', variants: 'Thiếu biến thể', brand: 'Thiếu hãng', categories: 'Thiếu danh mục' };
        return '<span class="supp-badge missing">' + (labels[m] || m) + '</span>';
      }).join('');
    }

    var imgHtml = p.image 
      ? '<img class="supp-card-img" src="' + escapeHtml(p.image) + '" alt="' + escapeHtml(p.name) + '" loading="lazy" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\';">'
      : '';
    var placeholderHtml = p.image ? '<div class="supp-card-img-placeholder" style="display:none;"><svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>' : '<div class="supp-card-img-placeholder"><svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>';

    html += '<div class="supp-card' + (selectedProductId === p._id ? ' selected' : '') + '" onclick="selectSupplementCard(\'' + p._id + '\')" data-id="' + p._id + '">' +
      imgHtml + placeholderHtml +
      '<div class="supp-card-body">' +
        '<div class="supp-card-name">' + escapeHtml(p.name) + '</div>' +
        '<div class="supp-card-brand">' + escapeHtml(p.brand || 'Chưa có hãng') + '</div>' +
        '<div class="supp-card-badges">' + badgesHtml + '</div>' +
      '</div>' +
    '</div>';
  });
  container.innerHTML = html;
}

// ── Scroll behavior: wheel up → box scrolls right, wheel down → box scrolls left ──
(function setupScroll() {
  var container = document.getElementById('supp-cards');
  if (!container) return;
  container.addEventListener('wheel', function(e) {
    e.preventDefault();
    // deltaY > 0 = scroll down → scroll left (ngược)
    container.scrollLeft += e.deltaY * 1.5;
  }, { passive: false });
})();

// ── Select card → redirect to product detail page ──
function selectSupplementCard(productId) {
  window.location.href = '/admin/products/supplement/' + productId;
}

// ── Update sidebar badge ──
function updateSidebarBadge(count) {
  var navItem = document.querySelector('.supplement-nav-item');
  var badge = document.querySelector('.supplement-count');
  if (navItem && badge) {
    if (count > 0) {
      navItem.style.display = 'flex';
      badge.textContent = count;
    } else {
      navItem.style.display = 'none';
    }
  }
}

// ── Init ──
loadSupplementProducts();
</script>