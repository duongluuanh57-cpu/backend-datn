<%# Trang Tạo Người dùng bằng AI %>
<script>window.__API_TOKEN__='<%= apiToken %>';</script>

<div id="ai-create-app">
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;flex-wrap:wrap;">
    <a href="/admin/users" style="display:inline-flex;align-items:center;gap:6px;color:var(--text-muted);text-decoration:none;font-size:13px;font-weight:500;padding:6px 12px;border-radius:8px;border:1px solid var(--border);" onmouseover="this.style.color='var(--accent)';this.style.borderColor='var(--accent)'" onmouseout="this.style.color='var(--text-muted)';this.style.borderColor='var(--border)'">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Quay lại Người dùng
    </a>
    <h2 style="font-size:18px;font-weight:600;color:var(--text-primary);margin:0;">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="var(--accent)" stroke-width="2" style="vertical-align:middle;margin-right:6px;"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      Tạo Người dùng bằng AI
    </h2>
  </div>

  <!-- ── Step 1: Prompt ── -->
  <div class="ai-card">
    <h3 style="font-size:14px;font-weight:600;margin:0 0 8px;color:var(--text-primary);">1. Mô tả người dùng</h3>
    <p style="font-size:12px;color:var(--text-muted);margin:0 0 12px;">Nhập mô tả về người dùng bạn muốn tạo. AI sẽ tự động sinh thông tin.</p>
    <textarea id="ai-prompt" rows="3" placeholder="VD: Tạo tài khoản admin cho nhân viên tên Nguyễn Văn A, số điện thoại 0912345678, quyền quản trị viên" style="width:100%;padding:10px 14px;border:1px solid var(--border);border-radius:10px;font-size:13px;font-family:inherit;color:var(--text-primary);background:var(--bg);resize:vertical;box-sizing:border-box;"></textarea>
    <div style="margin-top:12px;display:flex;gap:10px;">
      <button id="ai-generate-btn" onclick="generateUser()" style="display:flex;align-items:center;gap:6px;padding:10px 24px;border:none;border-radius:10px;background:var(--accent);color:#fff;cursor:pointer;font-size:13px;font-weight:600;box-shadow:0 2px 8px rgba(201,169,110,0.25);">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        AI Sinh thông tin
      </button>
    </div>
  </div>

  <!-- ── Loading ── -->
  <div id="ai-loading" style="display:none;text-align:center;padding:40px;color:var(--text-muted);">
    <svg style="animation:spin 1s linear infinite;width:28px;height:28px;margin:0 auto 12px;color:var(--accent);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
    AI đang tạo thông tin người dùng...
  </div>

  <!-- ── Step 2: Preview + Edit ── -->
  <div id="ai-result" style="display:none;">
    <div class="ai-card">
      <h3 style="font-size:14px;font-weight:600;margin:0 0 16px;color:var(--text-primary);display:flex;align-items:center;gap:8px;">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="var(--accent)" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        2. Preview & Chỉnh sửa
      </h3>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="ai-field">
          <label>Username</label>
          <input type="text" id="pv-username" class="ai-input" />
        </div>
        <div class="ai-field">
          <label>Email</label>
          <input type="email" id="pv-email" class="ai-input" />
        </div>
        <div class="ai-field">
          <label>Mật khẩu</label>
          <input type="text" id="pv-password" class="ai-input" />
        </div>
        <div class="ai-field">
          <label>Họ tên</label>
          <input type="text" id="pv-fullName" class="ai-input" />
        </div>
        <div class="ai-field">
          <label>Số điện thoại</label>
          <input type="text" id="pv-phoneNumber" class="ai-input" />
        </div>
        <div class="ai-field">
          <label>Vai trò</label>
          <select id="pv-role" class="ai-input">
            <option value="USER">USER</option>
            <option value="ADMIN">ADMIN</option>
            <option value="SUBADMIN">SUBADMIN</option>
          </select>
        </div>
      </div>
    </div>

    <!-- ── Action ── -->
    <div style="display:flex;gap:12px;margin-top:16px;">
      <button onclick="createUser()" style="display:flex;align-items:center;gap:6px;padding:10px 28px;border:none;border-radius:10px;background:var(--accent);color:#fff;cursor:pointer;font-size:13px;font-weight:600;box-shadow:0 2px 8px rgba(201,169,110,0.25);">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
        Tạo Người dùng
      </button>
      <button onclick="resetForm()" style="padding:10px 20px;border:1px solid var(--border);border-radius:10px;background:var(--surface);color:var(--text-primary);cursor:pointer;font-size:13px;font-weight:500;">Làm lại</button>
      <span id="ai-status" style="font-size:12px;align-self:center;color:var(--text-muted);"></span>
    </div>
  </div>
</div>

<style>
  .ai-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 20px;
    margin-bottom: 16px;
  }
  .ai-field {
    display:flex; flex-direction:column; gap:4px;
  }
  .ai-field label {
    font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; color:var(--text-muted);
  }
  .ai-input {
    padding:8px 12px; border:1px solid var(--border); border-radius:8px; font-size:13px; font-family:inherit; color:var(--text-primary); background:var(--bg);
  }
  .ai-input:focus { outline:none; border-color:var(--accent); box-shadow:0 0 0 2px rgba(201,169,110,0.1); }
  @keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
  @media (max-width:768px) {
    #ai-result > div:first-child > div:last-child { grid-template-columns:1fr; }
  }
</style>

<script>
var TOKEN = window.__API_TOKEN__;
var H = { 'Authorization': 'Bearer ' + TOKEN, 'Content-Type': 'application/json' };
var generatedData = null;

function $(id) { return document.getElementById(id); }

function generateUser() {
  var prompt = $('ai-prompt').value.trim();
  if (!prompt) { $('ai-prompt').focus(); $('ai-prompt').style.borderColor = 'var(--danger)'; return; }
  $('ai-prompt').style.borderColor = 'var(--border)';
  $('ai-loading').style.display = 'block';
  $('ai-result').style.display = 'none';

  fetch('/api/ai/generate-user', {
    method: 'POST',
    headers: H,
    body: JSON.stringify({ prompt: prompt })
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    $('ai-loading').style.display = 'none';
    if (res.success && res.data) {
      generatedData = res.data;
      $('pv-username').value = generatedData.username || '';
      $('pv-email').value = generatedData.email || '';
      $('pv-password').value = generatedData.password || '';
      $('pv-fullName').value = generatedData.fullName || '';
      $('pv-phoneNumber').value = generatedData.phoneNumber || '';
      $('pv-role').value = generatedData.role || 'USER';
      $('ai-result').style.display = 'block';
      $('ai-status').textContent = '✅ AI đã sinh thông tin thành công!';
      $('ai-status').style.color = '#16a34a';
    } else {
      $('ai-status').textContent = '❌ Lỗi: ' + (res.message || 'Không thể sinh dữ liệu');
      $('ai-status').style.color = 'var(--danger)';
    }
  })
  .catch(function() {
    $('ai-loading').style.display = 'none';
    $('ai-status').textContent = '❌ Lỗi kết nối';
    $('ai-status').style.color = 'var(--danger)';
  });
}

function createUser() {
  var userData = {
    username: $('pv-username').value.trim(),
    email: $('pv-email').value.trim(),
    password: $('pv-password').value.trim(),
    role: $('pv-role').value,
    fullName: $('pv-fullName').value.trim(),
    phoneNumber: $('pv-phoneNumber').value.trim(),
    status: 'active'
  };
  if (!userData.username || !userData.email || !userData.password) {
    $('ai-status').textContent = 'Vui lòng điền đầy đủ Username, Email và Mật khẩu';
    $('ai-status').style.color = 'var(--danger)';
    return;
  }
  $('ai-status').textContent = 'Đang tạo người dùng...';
  $('ai-status').style.color = 'var(--accent)';

  fetch('/api/ai/create-user', {
    method: 'POST',
    headers: H,
    body: JSON.stringify({ userData: userData })
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    if (res.success) {
      $('ai-status').textContent = '✅ Đã tạo người dùng thành công! Đang chuyển...';
      $('ai-status').style.color = '#16a34a';
      setTimeout(function() {
        window.location.href = '/admin/users?toast=Đã+tạo+người+dùng+bằng+AI&type=success';
      }, 1000);
    } else {
      $('ai-status').textContent = '❌ ' + (res.message || 'Không thể tạo người dùng');
      $('ai-status').style.color = 'var(--danger)';
    }
  })
  .catch(function() {
    $('ai-status').textContent = '❌ Lỗi kết nối';
    $('ai-status').style.color = 'var(--danger)';
  });
}

function resetForm() {
  generatedData = null;
  $('ai-result').style.display = 'none';
  $('ai-prompt').value = '';
  $('ai-status').textContent = '';
}
</script>