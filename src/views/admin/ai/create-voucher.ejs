<%# Trang Tạo Mã giảm giá bằng AI %>
<script>window.__API_TOKEN__='<%= apiToken %>';</script>

<div id="ai-create-app">
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;flex-wrap:wrap;">
    <a href="/admin/vouchers" style="display:inline-flex;align-items:center;gap:6px;color:var(--text-muted);text-decoration:none;font-size:13px;font-weight:500;padding:6px 12px;border-radius:8px;border:1px solid var(--border);" onmouseover="this.style.color='var(--accent)';this.style.borderColor='var(--accent)'" onmouseout="this.style.color='var(--text-muted)';this.style.borderColor='var(--border)'">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Quay lại Mã giảm giá
    </a>
    <h2 style="font-size:18px;font-weight:600;color:var(--text-primary);margin:0;">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="var(--accent)" stroke-width="2" style="vertical-align:middle;margin-right:6px;"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      Tạo Mã giảm giá bằng AI
    </h2>
  </div>

  <div class="ai-card">
    <h3 style="font-size:14px;font-weight:600;margin:0 0 8px;color:var(--text-primary);">1. Mô tả mã giảm giá</h3>
    <p style="font-size:12px;color:var(--text-muted);margin:0 0 12px;">Nhập mô tả về mã giảm giá bạn muốn tạo. AI sẽ tự động sinh tất cả thông tin.</p>
    <textarea id="ai-prompt" rows="3" class="ai-input" style="width:100%;box-sizing:border-box;resize:vertical;" placeholder="VD: Tạo mã giảm 20% cho đơn hàng trên 500k, có hiệu lực 30 ngày, tối đa 100 lượt"></textarea>
    <div style="margin-top:12px;">
      <button onclick="generateVoucher()" style="display:flex;align-items:center;gap:6px;padding:10px 24px;border:none;border-radius:10px;background:var(--accent);color:#fff;cursor:pointer;font-size:13px;font-weight:600;box-shadow:0 2px 8px rgba(201,169,110,0.25);">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        AI Sinh thông tin
      </button>
    </div>
  </div>

  <div id="ai-loading" style="display:none;text-align:center;padding:40px;color:var(--text-muted);">
    <svg style="animation:spin 1s linear infinite;width:28px;height:28px;margin:0 auto 12px;color:var(--accent);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
    AI đang tạo thông tin mã giảm giá...
  </div>

  <div id="ai-result" style="display:none;">
    <div class="ai-card">
      <h3 style="font-size:14px;font-weight:600;margin:0 0 16px;color:var(--text-primary);display:flex;align-items:center;gap:8px;">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="var(--accent)" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        2. Preview & Chỉnh sửa
      </h3>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div class="ai-field">
          <label>Mã giảm giá</label>
          <input type="text" id="pv-code" class="ai-input" />
        </div>
        <div class="ai-field">
          <label>Loại</label>
          <select id="pv-type" class="ai-input">
            <option value="percentage">Phần trăm (%)</option>
            <option value="fixed">Tiền mặt (VNĐ)</option>
          </select>
        </div>
        <div class="ai-field">
          <label>Giá trị</label>
          <input type="number" id="pv-value" class="ai-input" min="0" />
        </div>
        <div class="ai-field">
          <label>Đơn tối thiểu (VNĐ)</label>
          <input type="number" id="pv-minOrder" class="ai-input" min="0" />
        </div>
        <div class="ai-field">
          <label>Giảm tối đa (VNĐ)</label>
          <input type="number" id="pv-maxDiscount" class="ai-input" min="0" />
        </div>
        <div class="ai-field">
          <label>Số lượt tối đa (0 = không giới hạn)</label>
          <input type="number" id="pv-maxUsage" class="ai-input" min="0" />
        </div>
        <div class="ai-field">
          <label>Ngày bắt đầu</label>
          <input type="date" id="pv-startDate" class="ai-input" />
        </div>
        <div class="ai-field">
          <label>Ngày kết thúc</label>
          <input type="date" id="pv-endDate" class="ai-input" />
        </div>
      </div>
    </div>

    <div style="display:flex;gap:12px;margin-top:16px;">
      <button onclick="createVoucher()" style="display:flex;align-items:center;gap:6px;padding:10px 28px;border:none;border-radius:10px;background:var(--accent);color:#fff;cursor:pointer;font-size:13px;font-weight:600;box-shadow:0 2px 8px rgba(201,169,110,0.25);">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 12H4"/><path d="M2 7h20"/><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M12 12v4"/><path d="M10 14h4"/></svg>
        Tạo Mã giảm giá
      </button>
      <button onclick="resetForm()" style="padding:10px 20px;border:1px solid var(--border);border-radius:10px;background:var(--surface);color:var(--text-primary);cursor:pointer;font-size:13px;font-weight:500;">Làm lại</button>
      <span id="ai-status" style="font-size:12px;align-self:center;color:var(--text-muted);"></span>
    </div>
  </div>
</div>

<style>
  .ai-card { background:var(--surface); border:1px solid var(--border); border-radius:14px; padding:20px; margin-bottom:16px; }
  .ai-field { display:flex; flex-direction:column; gap:4px; }
  .ai-field label { font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; color:var(--text-muted); }
  .ai-input { padding:8px 12px; border:1px solid var(--border); border-radius:8px; font-size:13px; font-family:inherit; color:var(--text-primary); background:var(--bg); }
  .ai-input:focus { outline:none; border-color:var(--accent); box-shadow:0 0 0 2px rgba(201,169,110,0.1); }
  @keyframes spin { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }
  @media (max-width:768px) { #ai-result > div:first-child > div:last-child { grid-template-columns:1fr; } }
</style>

<script>
var TOKEN = window.__API_TOKEN__;
var H = { 'Authorization': 'Bearer ' + TOKEN, 'Content-Type': 'application/json' };

function $(id) { return document.getElementById(id); }

function generateVoucher() {
  var prompt = $('ai-prompt').value.trim();
  if (!prompt) { $('ai-prompt').focus(); $('ai-prompt').style.borderColor = 'var(--danger)'; return; }
  $('ai-prompt').style.borderColor = 'var(--border)';
  $('ai-loading').style.display = 'block';
  $('ai-result').style.display = 'none';

  fetch('/api/ai/generate-voucher', {
    method: 'POST',
    headers: H,
    body: JSON.stringify({ prompt: prompt })
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    $('ai-loading').style.display = 'none';
    if (res.success && res.data) {
      $('pv-code').value = res.data.code || '';
      $('pv-type').value = res.data.type || 'percentage';
      $('pv-value').value = res.data.value || 0;
      $('pv-minOrder').value = res.data.minOrderAmount || 0;
      $('pv-maxDiscount').value = res.data.maxDiscount || 0;
      $('pv-maxUsage').value = res.data.maxUsage || 0;
      // Format dates for date input (YYYY-MM-DD)
      if (res.data.startDate) {
        var sd = new Date(res.data.startDate);
        $('pv-startDate').value = sd.toISOString().slice(0,10);
      }
      if (res.data.endDate) {
        var ed = new Date(res.data.endDate);
        $('pv-endDate').value = ed.toISOString().slice(0,10);
      }
      $('ai-result').style.display = 'block';
      $('ai-status').textContent = '✅ AI đã sinh thông tin thành công!';
      $('ai-status').style.color = '#16a34a';
    } else {
      $('ai-status').textContent = '❌ Lỗi: ' + (res.message || 'Không thể sinh dữ liệu');
      $('ai-status').style.color = 'var(--danger)';
    }
  })
  .catch(function() {
    $('ai-loading').style.display = 'none';
    $('ai-status').textContent = '❌ Lỗi kết nối';
    $('ai-status').style.color = 'var(--danger)';
  });
}

function createVoucher() {
  var voucherData = {
    code: $('pv-code').value.trim(),
    type: $('pv-type').value,
    value: Number($('pv-value').value) || 0,
    minOrderAmount: Number($('pv-minOrder').value) || 0,
    maxDiscount: Number($('pv-maxDiscount').value) || undefined,
    maxUsage: Number($('pv-maxUsage').value) || 0,
    startDate: $('pv-startDate').value,
    endDate: $('pv-endDate').value,
    status: 'active'
  };
  if (!voucherData.code || !voucherData.startDate || !voucherData.endDate) {
    $('ai-status').textContent = 'Vui lòng nhập Mã, Ngày bắt đầu và Ngày kết thúc';
    $('ai-status').style.color = 'var(--danger)';
    return;
  }
  $('ai-status').textContent = 'Đang tạo mã giảm giá...';
  $('ai-status').style.color = 'var(--accent)';

  fetch('/api/ai/create-voucher', {
    method: 'POST',
    headers: H,
    body: JSON.stringify({ voucherData: voucherData })
  })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    if (res.success) {
      $('ai-status').textContent = '✅ Đã tạo mã giảm giá thành công! Đang chuyển...';
      $('ai-status').style.color = '#16a34a';
      setTimeout(function() {
        window.location.href = '/admin/vouchers?toast=Đã+tạo+mã+giảm+giá+bằng+AI&type=success';
      }, 1000);
    } else {
      $('ai-status').textContent = '❌ ' + (res.message || 'Không thể tạo mã giảm giá');
      $('ai-status').style.color = 'var(--danger)';
    }
  })
  .catch(function() {
    $('ai-status').textContent = '❌ Lỗi kết nối';
    $('ai-status').style.color = 'var(--danger)';
  });
}

function resetForm() {
  $('ai-result').style.display = 'none';
  $('ai-prompt').value = '';
  $('ai-status').textContent = '';
}
</script>