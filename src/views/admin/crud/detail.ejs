<div id="product-detail">
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:24px;flex-wrap:wrap;">
    <a href="/admin/products" style="display:inline-flex;align-items:center;gap:6px;color:var(--text-muted);text-decoration:none;font-size:13px;font-weight:500;padding:6px 12px;border-radius:8px;border:1px solid var(--border);" onmouseover="this.style.color='var(--accent)';this.style.borderColor='var(--accent)'" onmouseout="this.style.color='var(--text-muted)';this.style.borderColor='var(--border)'">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Quay lại danh sách
    </a>
    <span style="color:var(--text-muted);">/</span>
    <span id="detail-breadcrumb" style="color:var(--text-primary);font-weight:600;font-size:14px;">Đang tải...</span>
  </div>

  <div id="detail-loading" style="text-align:center;padding:80px 20px;color:var(--text-muted);">
    <svg style="animation:spin 1s linear infinite;width:32px;height:32px;margin:0 auto 16px;display:block;color:var(--accent);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
    Đang tải thông tin sản phẩm...
  </div>

  <div id="detail-content" style="display:none;"></div>
  <div id="detail-error" style="display:none;text-align:center;padding:80px 20px;color:var(--danger);"></div>
</div>

<style>
  .scent-meta-item{display:flex;align-items:center;gap:8px;padding:10px 14px;background:var(--bg, #fafafa);border-radius:8px;border:1px solid var(--border);}
  .scent-meta-icon{width:20px;height:20px;color:var(--accent);flex-shrink:0;}
  .scent-meta-icon svg{width:100%;height:100%;}
  .scent-meta-label{font-size:11px;color:var(--text-muted);min-width:100px;text-transform:uppercase;letter-spacing:0.5px;}
  .scent-meta-value{font-size:13px;font-weight:500;color:var(--text-primary);}
  .dt-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px;margin-top:24px;}
  .dt-card h3{font-size:16px;font-weight:600;margin:0 0 12px;color:var(--text-primary);}
  .dt-stat{background:var(--surface);padding:10px 18px;border-radius:10px;text-align:center;border:1px solid var(--border);}
  .dt-stat-num{font-size:20px;font-weight:700;color:var(--text-primary);}
  .dt-stat-label{font-size:11px;color:var(--text-muted);}
  @keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
</style>

<script>
var PRODUCT_ID = '<%= productId %>';
var TOKEN = '<%= apiToken %>';
var TENANT = '<%= tenantId || 'default' %>';
var H = { 'Authorization': 'Bearer ' + TOKEN };

function $(id) { return document.getElementById(id); }
function fmt(n) { return (n || 0).toLocaleString('vi-VN'); }
function fmtCurrency(n) { return fmt(n) + 'đ'; }
function fmtDate(d) { return d ? new Date(d).toLocaleDateString('vi-VN') : '—'; }
function escapeHtml(str) {
  if (!str) return '';
  return String(str).replace(/[&<>"']/g, function(m){ return {'&':'&','<':'<','>':'>','"':'"',"'":'&#39;'}[m]||m; });
}

function renderScentMeta(p) {
  var meta = [
    { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>', label: 'Độ lưu hương', value: p.longevity },
    { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>', label: 'Độ tỏa hương', value: p.sillage },
    { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20V10M18 20V4M6 20v-4"/></svg>', label: 'Độ bền', value: p.durability },
    { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>', label: 'Hương đặc trưng', value: p.scentTrail },
    { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>', label: 'Phong cách', value: p.style },
    { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>', label: 'Phù hợp', value: p.suitableFor },
    { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>', label: 'Dịp', value: p.occasion },
    { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>', label: 'Mùa', value: p.season },
    { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/></svg>', label: 'Thời điểm', value: p.time },
  ];
  var html = '';
  meta.forEach(function(m) {
    var val = m.value || '—';
    html += '<div class="scent-meta-item">'+
      '<span class="scent-meta-icon">'+m.icon+'</span>'+
      '<span class="scent-meta-label">'+m.label+'</span>'+
      '<span class="scent-meta-value">'+escapeHtml(val)+'</span>'+
    '</div>';
  });
  return html;
}

fetch('/api/products/' + PRODUCT_ID + '?tenantId=' + TENANT, { headers: H })
  .then(function(r) { return r.json(); })
  .then(function(res) {
    if (!res.success || !res.data) {
      $('detail-loading').style.display = 'none';
      $('detail-error').style.display = 'block';
      $('detail-error').innerHTML = '<p style="font-size:16px;font-weight:600;">Không tìm thấy sản phẩm</p><p style="margin-top:8px;font-size:13px;">Sản phẩm có thể đã bị xóa hoặc không tồn tại.</p>';
      return;
    }
    var p = res.data;
    $('detail-breadcrumb').textContent = (p.brand || '') + ' · ' + (p.name || '');
    document.title = (p.name || 'Sản phẩm') + ' — Admin';

    var catArr = Array.isArray(p.categories) ? p.categories : [];
    var catBadges = catArr.length ? catArr.map(function(name){ return '<span style="display:inline-block;padding:2px 10px;background:rgba(201,169,110,0.1);color:var(--accent);border-radius:20px;font-size:12px;font-weight:500;">'+escapeHtml(name)+'</span>'; }).join(' ') : '<span style="color:var(--text-muted);font-size:12px;">—</span>';

    var tags = p.tag ? p.tag.split(',').map(function(t){ return t.trim(); }).filter(Boolean) : [];
    var tagBadges = tags.length ? tags.map(function(t){ return '<span style="display:inline-block;padding:2px 10px;background:var(--surface);color:var(--text-secondary);border-radius:20px;font-size:12px;border:1px solid var(--border);">'+escapeHtml(t)+'</span>'; }).join(' ') : '<span style="color:var(--text-muted);font-size:12px;">—</span>';

    var variants = Array.isArray(p.variants) ? p.variants : [];
    var varRows = variants.length > 0 ? variants.map(function(v){
      return '<tr>'+
        '<td style="font-weight:500;">'+escapeHtml(v.size || '—')+'</td>'+
        '<td>'+fmtCurrency(v.price)+'</td>'+
        '<td>'+fmt(v.quantityInStock)+'</td>'+
        '<td>'+(v.isDefault ? '<span style="color:var(--accent);font-weight:600;">Mặc định</span>' : '—')+'</td>'+
      '</tr>';
    }).join('') : '<tr><td colspan="4" style="text-align:center;color:var(--text-muted);padding:20px;">Không có biến thể</td></tr>';

    var images = Array.isArray(p.images) ? p.images : [];
    var allImages = images.length > 0 ? images : (p.image ? [p.image] : []);
    var imgHtml = allImages.length > 0 ? allImages.map(function(url){ 
      return '<div style="width:100px;height:100px;border-radius:10px;overflow:hidden;border:1px solid var(--border);flex-shrink:0;"><img src="'+url+'" alt="" style="width:100%;height:100%;object-fit:cover;" /></div>';
    }).join('') : '<span style="color:var(--text-muted);font-size:13px;">Không có ảnh</span>';

    var discount = p.discount || 0;
    var discountHTML = discount > 0 
      ? '<span style="color:#ef4444;font-weight:600;">-' + discount + '%</span>'
      : '<span style="color:var(--text-muted);">Không có</span>';

    var mainImage = p.image ? '<img src="'+p.image+'" alt="" style="width:100%;height:100%;object-fit:cover;" />' : '<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:var(--text-muted);background:var(--surface);">Không có ảnh</div>';

    var sideImages = allImages.length > 1 ? '<div style="display:flex;gap:8px;margin-top:12px;flex-wrap:wrap;">'+allImages.map(function(url){
      return '<div style="width:60px;height:60px;border-radius:8px;overflow:hidden;border:1px solid var(--border);flex-shrink:0;background:var(--surface);"><img src="'+url+'" alt="" style="width:100%;height:100%;object-fit:cover;" /></div>';
    }).join('')+'</div>' : '';

    var html = '<div style="display:flex;gap:24px;flex-wrap:wrap;">'+
      '<div style="width:260px;flex-shrink:0;">'+
        '<div style="width:260px;height:260px;border-radius:16px;overflow:hidden;border:1px solid var(--border);background:var(--surface);">'+mainImage+'</div>'+
        sideImages+
      '</div>'+
      '<div style="flex:1;min-width:240px;">'+
        '<h2 style="font-size:22px;font-weight:700;color:var(--text-primary);margin:0 0 4px;line-height:1.3;">'+escapeHtml(p.name)+'</h2>'+
        '<p style="font-size:14px;color:var(--text-muted);margin:0 0 16px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;">'+
          '<strong style="color:var(--accent);">'+escapeHtml(p.brand || '—')+'</strong>'+
          (p.brandId && p.brandId.origin ? '<span style="opacity:0.6;">· '+escapeHtml(p.brandId.origin)+'</span>' : '')+
        '</p>'+
        '<div style="display:flex;align-items:baseline;gap:12px;margin-bottom:16px;flex-wrap:wrap;">'+
          '<span style="font-size:28px;font-weight:700;color:var(--text-primary);">'+fmtCurrency(p.price)+'</span>'+
          (p.originalPrice && p.originalPrice > p.price ? '<span style="font-size:16px;color:var(--text-muted);text-decoration:line-through;">'+fmtCurrency(p.originalPrice)+'</span>' : '')+
          discountHTML+
        '</div>'+
        '<div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:16px;">'+
          '<div class="dt-stat"><div class="dt-stat-num">'+fmt(p.soldCount||0)+'</div><div class="dt-stat-label">Đã bán</div></div>'+
          '<div class="dt-stat"><div class="dt-stat-num">'+fmt(p.viewCount||0)+'</div><div class="dt-stat-label">Lượt xem</div></div>'+
          '<div class="dt-stat"><div class="dt-stat-num" style="color:var(--accent);">'+fmt(p.rating||0)+'</div><div class="dt-stat-label">Đánh giá</div></div>'+
          '<div class="dt-stat"><div class="dt-stat-num">'+fmt(p.reviewsCount||0)+'</div><div class="dt-stat-label">Review</div></div>'+
        '</div>'+
        '<div style="display:flex;flex-direction:column;gap:8px;font-size:13px;">'+
          '<div><span style="color:var(--text-muted);">Danh mục:</span> '+catBadges+'</div>'+
          '<div><span style="color:var(--text-muted);">Tags:</span> '+tagBadges+'</div>'+
          '<div><span style="color:var(--text-muted);">Tồn kho:</span> <strong>'+fmt(p.quantityInStock)+'</strong></div>'+
        '</div>'+
      '</div>'+
    '</div>'+

    // Description
    '<div class="dt-card">'+
      '<h3>Mô tả</h3>'+
      '<div style="font-size:14px;line-height:1.7;color:var(--text-secondary);white-space:pre-wrap;">'+escapeHtml(p.description || 'Chưa có mô tả')+'</div>'+
    '</div>'+

    // Variants Table
    '<div class="dt-card">'+
      '<h3>Biến thể ('+fmt(variants.length)+')</h3>'+
      '<div style="overflow-x:auto;">'+
        '<table class="data-table" style="border-radius:8px;">'+
          '<thead><tr><th>Dung tích</th><th>Giá</th><th>Tồn kho</th><th>Mặc định</th></tr></thead>'+
          '<tbody>'+varRows+'</tbody>'+
        '</table>'+
      '</div>'+
    '</div>'+

    // Scent Attributes
    '<div class="dt-card">'+
      '<h3>Thuộc tính nước hoa</h3>'+
      '<div style="display:grid;grid-template-columns:repeat(auto-fill, minmax(240px, 1fr));gap:10px;">'+
        renderScentMeta(p)+
      '</div>'+
    '</div>'+

    // Brand Info + Meta — same row (2-col grid)
    '<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:24px;">'+
      (p.brandId && p.brandId.name ?
        '<div class="dt-card" style="margin-top:0;">'+
          '<h3>Thương hiệu</h3>'+
          '<div style="display:flex;gap:16px;align-items:center;flex-wrap:wrap;">'+
            (p.brandId.logo ? '<img src="'+p.brandId.logo+'" alt="" style="width:64px;height:64px;object-fit:contain;border-radius:8px;background:var(--surface);" />' : '')+
            '<div>'+
              '<p style="font-size:16px;font-weight:600;color:var(--text-primary);margin:0;">'+escapeHtml(p.brandId.name || '')+'</p>'+
              (p.brandId.origin ? '<p style="font-size:13px;color:var(--text-muted);margin:4px 0 0;">Xuất xứ: '+escapeHtml(p.brandId.origin)+'</p>' : '')+
              (p.brandId.description ? '<p style="font-size:13px;color:var(--text-secondary);margin:8px 0 0;max-width:500px;">'+escapeHtml(p.brandId.description)+'</p>' : '')+
            '</div>'+
          '</div>'+
        '</div>'
      : '<div class="dt-card" style="margin-top:0;"><h3>Thương hiệu</h3><p style="color:var(--text-muted);font-size:13px;">—</p></div>')+
      '<div class="dt-card" style="margin-top:0;">'+
        '<h3>Thông tin hệ thống</h3>'+
        '<div style="display:grid;grid-template-columns:repeat(auto-fill, minmax(200px, 1fr));gap:8px;font-size:13px;">'+
          '<div><span style="color:var(--text-muted);">ID:</span> <span style="font-family:monospace;font-size:12px;">'+p._id+'</span></div>'+
          '<div><span style="color:var(--text-muted);">Tenant:</span> <span style="font-family:monospace;font-size:12px;">'+(p.tenantId||'—')+'</span></div>'+
          '<div><span style="color:var(--text-muted);">Ngày tạo:</span> '+fmtDate(p.createdAt)+'</div>'+
          '<div><span style="color:var(--text-muted);">Cập nhật:</span> '+fmtDate(p.updatedAt)+'</div>'+
        '</div>'+
      '</div>'+
    '</div>';

    $('detail-loading').style.display = 'none';
    $('detail-content').style.display = 'block';
    $('detail-content').innerHTML = html;
  })
  .catch(function() {
    $('detail-loading').style.display = 'none';
    $('detail-error').style.display = 'block';
    $('detail-error').innerHTML = '<p style="font-size:16px;font-weight:600;">Lỗi kết nối</p><p style="margin-top:8px;font-size:13px;">Không thể tải thông tin sản phẩm. Vui lòng thử lại.</p>';
  });
</script>