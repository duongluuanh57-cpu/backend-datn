<%# Generic CRUD List Template — client-side fetch with bulk actions %>
<script>window.__API_TOKEN__='<%= apiToken %>';window.__ADMIN_CONFIG__=<%- config %>;</script>

<div id="crud-app">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:12px;">
    <div style="display:flex;gap:8px;">
      <input type="text" id="crud-search" placeholder="" class="admin-input" style="width:260px;">
      <button onclick="crudSearch()" class="admin-btn admin-btn-primary" style="padding:8px 16px;font-size:13px;">Tìm</button>
      <a id="crud-clear-search" href="#" style="color:var(--text-muted);text-decoration:none;font-size:13px;padding:8px;display:none;">Xóa lọc</a>
    </div>
    <div style="display:flex;align-items:center;gap:12px;">
      <a href="/admin/products/supplement" id="supplement-link" style="display:none;align-items:center;gap:6px;background:rgba(245,158,11,0.1);color:#d97706;text-decoration:none;font-size:13px;font-weight:600;padding:8px 14px;border-radius:8px;border:1px solid rgba(245,158,11,0.2);"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg> Bổ sung <span id="supplement-count" style="background:#d97706;color:#fff;border-radius:10px;padding:1px 8px;font-size:11px;min-width:18px;text-align:center;">0</span></a>
      <span style="color:var(--text-muted);font-size:13px;">Tổng: <b id="crud-total" style="color:var(--text-primary);">0</b></span>
    </div>
  </div>

  <div style="overflow-x:auto;">
    <table class="data-table">
      <thead><tr id="crud-thead"></tr></thead>
      <tbody id="crud-tbody">
        <tr><td colspan="99" style="text-align:center;padding:40px;color:var(--text-muted);">Đang tải...</td></tr>
      </tbody>
    </table>
  </div>

  <div id="crud-pagination" style="display:flex;justify-content:center;gap:6px;margin-top:20px;"></div>
</div>

<!-- ── Bulk action bar (toast) ── -->
<div id="bulk-bar" style="position:fixed;bottom:24px;left:50%;transform:translateX(-50%);display:none;align-items:center;gap:12px;background:#1e1e2e;color:#fff;padding:10px 20px;border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,0.3);z-index:1000;font-size:14px;">
  <span id="bulk-count">0 sản phẩm đã chọn</span>
  <button onclick="bulkDelete()" id="bulk-delete-btn" style="background:#ef4444;color:#fff;border:none;padding:6px 16px;border-radius:8px;cursor:pointer;font-weight:600;font-size:13px;"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:middle;margin-right:4px;"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>Xóa</button>
  <button onclick="clearBulkSelection()" style="background:none;border:1px solid rgba(255,255,255,0.3);color:rgba(255,255,255,0.7);padding:6px 12px;border-radius:8px;cursor:pointer;font-size:13px;">✕ Bỏ chọn</button>
</div>

<style>
  #crud-tbody tr.selected { background: rgba(201,169,110,0.06); }
  .checkbox-col { width: 40px; text-align: center; }
  .checkbox-col input[type="checkbox"] { width: 16px; height: 16px; cursor: pointer; accent-color: #C9A96E; }
  #bulk-bar { transition: transform 0.25s ease, opacity 0.25s ease; }
</style>

<script>
var C = window.__ADMIN_CONFIG__;
var PAGE = 1;
var SEARCH = '';
var LIMIT = 10;
var TOTAL_PAGES = 1;
var ALL_ITEMS = [];       // current page items (with _id)
var SELECTED = new Set(); // set of selected _id

var COLORS = { pending:'#f59e0b', processing:'#3b82f6', shipped:'#8b5cf6', delivered:'#22c55e', cancelled:'#ef4444' };
var STATUS_LABELS = { pending:'Chờ XL', processing:'Đang XL', shipped:'Đang giao', delivered:'Đã giao', cancelled:'Đã hủy' };

document.getElementById('crud-search').placeholder = C.searchPlaceholder || 'Tìm kiếm...';
document.getElementById('crud-search').addEventListener('keydown', function(e) { if (e.key === 'Enter') { e.preventDefault(); crudSearch(); } });

// ── Build header with checkbox column ──
var thead = document.getElementById('crud-thead');
var thCheck = document.createElement('th');
thCheck.className = 'checkbox-col';
var cbAll = document.createElement('input');
cbAll.type = 'checkbox';
cbAll.title = 'Chọn tất cả';
cbAll.onchange = function() { toggleSelectAll(this.checked); };
thCheck.appendChild(cbAll);
thead.appendChild(thCheck);

C.columns.forEach(function(c) {
  var th = document.createElement('th');
  th.textContent = c.label;
  thead.appendChild(th);
});

function v(val, fallback) { return (val !== undefined && val !== null && val !== '') ? val : (fallback || '—'); }

function fmtCurrency(n) { return (Number(n) || 0).toLocaleString('vi-VN') + 'đ'; }
function fmtDate(d) { return d ? new Date(d).toLocaleDateString('vi-VN') : '—'; }
function fmtDateTime(d) { return d ? new Date(d).toLocaleString('vi-VN') : '—'; }

function cellContent(row, col) {
  var val = row[col.key];
  if (col.format === 'currency') return fmtCurrency(val);
  if (col.format === 'date') return fmtDate(val);
  if (col.format === 'dateTime') return fmtDateTime(val);

  if (col.render === 'status') {
    var s = val || '';
    var label = (col.statusMap && col.statusMap[s]) || s || (col.fallbackStatus || 'Ẩn');
    var color = (col.colorMap && col.colorMap[s]) || (col.fallbackColor || '#ef4444');
    return '<span style="color:' + color + '">' + label + '</span>';
  }
  if (col.render === 'orderStatus') {
    var s = val || '';
    var label = STATUS_LABELS[s] || s;
    var color = COLORS[s] || '#94a3b8';
    return '<span style="color:' + color + '">' + label + '</span>';
  }
  if (col.render === 'role') {
    var rc = { ADMIN: '#ef4444', SUBADMIN: '#f59e0b', USER: '#22c55e' };
    return '<span style="color:' + (rc[val] || '#94a3b8') + '">' + v(val) + '</span>';
  }
  if (col.render === 'voucherValue') {
    if (row.type === 'percentage') return (Number(row.value) || 0) + '%';
    return fmtCurrency(row.value);
  }
  return v(val);
}

function deepGet(obj, path) {
  if (!path) return obj;
  return path.split('.').reduce(function(o, k) { return (o && o[k] !== undefined) ? o[k] : null; }, obj);
}

// ── Bulk selection ──
function toggleSelectAll(checked) {
  ALL_ITEMS.forEach(function(row) {
    if (checked) { SELECTED.add(row._id); }
    else         { SELECTED.delete(row._id); }
  });
  updateBulkBar();
  updateSelectAllCb();
  rerenderCheckboxes();
}

function toggleSelectOne(id, checked) {
  if (checked) { SELECTED.add(id); } else { SELECTED.delete(id); }
  updateBulkBar();
  updateSelectAllCb();
}

function updateBulkBar() {
  var bar = document.getElementById('bulk-bar');
  var count = SELECTED.size;
  if (count > 0) {
    bar.style.display = 'flex';
    document.getElementById('bulk-count').textContent = count + ' sản phẩm đã chọn';
    document.getElementById('bulk-delete-btn').textContent = '🗑 Xóa (' + count + ')';
  } else {
    bar.style.display = 'none';
  }
}

function updateSelectAllCb() {
  var cb = thead.querySelector('input[type="checkbox"]');
  if (!cb) return;
  if (ALL_ITEMS.length === 0) { cb.checked = false; cb.indeterminate = false; return; }
  var allSelected = ALL_ITEMS.every(function(r) { return SELECTED.has(r._id); });
  var someSelected = ALL_ITEMS.some(function(r) { return SELECTED.has(r._id); });
  cb.checked = allSelected;
  cb.indeterminate = someSelected && !allSelected;
}

function rerenderCheckboxes() {
  var rows = document.querySelectorAll('#crud-tbody tr[data-id]');
  rows.forEach(function(tr) {
    var cb = tr.querySelector('input[type="checkbox"]');
    if (cb) cb.checked = SELECTED.has(tr.getAttribute('data-id'));
    tr.classList.toggle('selected', SELECTED.has(tr.getAttribute('data-id')));
  });
}

function clearBulkSelection() {
  SELECTED.clear();
  updateBulkBar();
  updateSelectAllCb();
  rerenderCheckboxes();
}

function bulkDelete() {
  var ids = Array.from(SELECTED);
  if (ids.length === 0) return;
  showToast('Đang xóa ' + ids.length + ' sản phẩm...', 'info');

  fetch('/api/products/bulk-delete', {
    method: 'POST',
    headers: { 'Authorization': 'Bearer ' + window.__API_TOKEN__, 'Content-Type': 'application/json' },
    body: JSON.stringify({ ids: ids })
  })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (res.success) {
        showToast('✅ Đã xóa ' + ids.length + ' sản phẩm thành công!', 'success');
        SELECTED.clear();
        updateBulkBar();
        crudFetch();
      } else {
        showToast('❌ Lỗi: ' + (res.message || 'Không thể xóa'), 'error');
      }
    })
    .catch(function() {
      showToast('❌ Lỗi kết nối đến server', 'error');
    });
}

// ── Render table ──
function renderTable(items) {
  ALL_ITEMS = items || [];
  var tbody = document.getElementById('crud-tbody');
  if (!items || items.length === 0) {
    tbody.innerHTML = '<tr><td colspan="99" style="text-align:center;padding:40px;color:var(--text-muted);">Không có dữ liệu</td></tr>';
    updateBulkBar();
    return;
  }
  var html = '';
  items.forEach(function(row) {
    var sel = SELECTED.has(row._id) ? ' selected' : '';
    var checked = SELECTED.has(row._id) ? ' checked' : '';
    html += '<tr data-id="' + row._id + '" class="' + sel + '">';
    html += '<td class="checkbox-col" onclick="event.stopPropagation()"><input type="checkbox" ' + checked + ' onchange="toggleSelectOne(\'' + row._id + '\', this.checked)"></td>';
    C.columns.forEach(function(col) {
      html += '<td>' + cellContent(row, col) + '</td>';
    });
    html += '</tr>';
  });
  tbody.innerHTML = html;

  // Make rows clickable (navigate to detail)
  if (C.detailEndpoint) {
    tbody.querySelectorAll('tr[data-id]').forEach(function(tr) {
      tr.style.cursor = 'pointer';
      tr.addEventListener('click', function(e) {
        // Ignore clicks on checkbox
        if (e.target.tagName === 'INPUT') return;
        location.href = C.detailEndpoint.replace(':id', tr.getAttribute('data-id'));
      });
    });
  }

  updateSelectAllCb();
  updateBulkBar();
}

function renderPagination() {
  var el = document.getElementById('crud-pagination');
  if (!TOTAL_PAGES || TOTAL_PAGES <= 1) { el.innerHTML = ''; return; }
  var html = '';
  for (var p = 1; p <= TOTAL_PAGES; p++) {
    var active = p === PAGE;
    html += '<button onclick="crudGoPage(' + p + ')" style="padding:6px 14px;border-radius:6px;border:none;cursor:pointer;font-size:13px;' + (active ? 'background:var(--color-primary);color:#fff;' : 'background:var(--color-surface);color:var(--color-text-secondary);') + '">' + p + '</button>';
  }
  el.innerHTML = html;
}

function crudFetch() {
  var url = C.apiEndpoint + '?page=' + PAGE + '&limit=' + LIMIT;
  if (SEARCH) url += '&search=' + encodeURIComponent(SEARCH);
  document.getElementById('crud-tbody').innerHTML = '<tr><td colspan="99" style="text-align:center;padding:40px;color:var(--text-muted);">Đang tải...</td></tr>';

  fetch(url, { headers: { 'Authorization': 'Bearer ' + window.__API_TOKEN__ } })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (!res.success) { document.getElementById('crud-tbody').innerHTML = '<tr><td colspan="99" style="text-align:center;padding:40px;color:var(--danger);">Lỗi tải dữ liệu</td></tr>'; return; }
      var data = res.data;
      var items = C.itemsPath ? deepGet(data, C.itemsPath) : data;
      var total = C.totalPath ? deepGet(data, C.totalPath) : (data && data.total);
      var totalPages = C.totalPagesPath ? deepGet(data, C.totalPagesPath) : (data && data.totalPages);
      if (!items && Array.isArray(data)) items = data;
      if (!total && items) total = items.length;
      if (!totalPages && total) totalPages = Math.ceil(total / LIMIT);
      TOTAL_PAGES = totalPages || 1;
      document.getElementById('crud-total').textContent = total || 0;
      renderTable(items || []);
      renderPagination();
      document.getElementById('crud-clear-search').style.display = SEARCH ? 'inline' : 'none';
    })
    .catch(function() {
      document.getElementById('crud-tbody').innerHTML = '<tr><td colspan="99" style="text-align:center;padding:40px;color:var(--danger);">Lỗi kết nối</td></tr>';
    });
}

function crudSearch() {
  SEARCH = document.getElementById('crud-search').value.trim();
  PAGE = 1;
  crudFetch();
}

function crudGoPage(p) {
  PAGE = p;
  crudFetch();
}

document.getElementById('crud-clear-search').addEventListener('click', function(e) {
  e.preventDefault();
  document.getElementById('crud-search').value = '';
  SEARCH = '';
  PAGE = 1;
  crudFetch();
});

crudFetch();

// ── Fetch supplement count badge cho product list ──
(function() {
  if (C.entityName !== 'product') return;
  fetch('/api/products/needs-supplement', { headers: { 'Authorization': 'Bearer ' + window.__API_TOKEN__ } })
    .then(function(r) { return r.json(); })
    .then(function(res) {
      if (!res.success) return;
      var count = res.data ? res.data.length : 0;
      var link = document.getElementById('supplement-link');
      var badge = document.getElementById('supplement-count');
      if (link && badge && count > 0) {
        link.style.display = 'flex';
        badge.textContent = count;
      }
    })
    .catch(function() {});
})();
</script>