<!-- ─── Hàng 1: Thẻ KPI ─── -->
<div class="stat-grid" style="grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));">
  <div class="stat-card">
    <div class="stat-icon blue"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg></div>
    <div><div class="stat-value" id="kpi-totalProducts">—</div><div class="stat-label">Tổng sản phẩm</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon green"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg></div>
    <div><div class="stat-value" id="kpi-revenueToday">—</div><div class="stat-label">Doanh thu hôm nay</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon amber"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg></div>
    <div><div class="stat-value" id="kpi-newOrdersToday">—</div><div class="stat-label">Đơn hàng hôm nay</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon blue"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></div>
    <div><div class="stat-value" id="kpi-visitsToday">—</div><div class="stat-label">Lượt truy cập</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon red"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg></div>
    <div><div class="stat-value" id="kpi-lowStockCount">—</div><div class="stat-label">Sắp hết hàng</div></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon amber"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
    <div><div class="stat-value" id="kpi-totalUsers">—</div><div class="stat-label">Tổng người dùng</div></div>
  </div>
</div>

<!-- ─── Hàng 2: Doanh thu + Xu hướng hiệu suất ─── -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px;">
  <div class="chart-section">
    <h4 style="font-size:15px;font-weight:600;margin-bottom:16px;">Doanh thu & Đơn hàng 7 ngày qua</h4>
    <canvas id="chartRevenue7d" style="max-height:260px;"></canvas>
  </div>
  <div class="chart-section" id="trendSection">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:12px;">
      <h4 style="font-size:15px;font-weight:600;">Hiệu suất hiện tại so với kỳ trước</h4>
      <div class="metric-switcher" id="metricSwitcher">
        <button class="metric-btn active" data-metric="add_to_cart">Thêm giỏ hàng</button>
        <button class="metric-btn" data-metric="reach_checkout">Thanh toán</button>
        <button class="metric-btn" data-metric="purchase">Mua hàng</button>
      </div>
    </div>
    <canvas id="chartTrend" style="max-height:260px;"></canvas>
  </div>
</div>

<!-- ─── Hàng 3: Top sản phẩm + Báo cáo chuyển đổi thương hiệu ─── -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:24px;">
  <div class="chart-section">
    <h4 style="font-size:15px;font-weight:600;margin-bottom:16px;">Khách mới & Quay lại theo thương hiệu</h4>
    <canvas id="chartRetention" style="max-height:260px;"></canvas>
  </div>
  <div class="chart-section">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
      <h4 style="font-size:15px;font-weight:600;">Phễu chuyển đổi</h4>
      <div class="custom-select" id="funnelBrandFilter">
        <button class="custom-select-trigger" type="button">
          <span class="custom-select-label">Chọn thương hiệu</span>
          <svg class="custom-select-chevron" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="custom-select-dropdown">
          <div class="custom-select-search-wrap"><input class="custom-select-search" type="text" placeholder="Tìm thương hiệu..."></div>
          <div class="custom-select-items"></div>
        </div>
      </div>
    </div>
    <div id="funnelContainer" style="min-height:200px;"><p style="color:var(--text-muted);text-align:center;padding:40px;">Đang tải...</p></div>
  </div>
</div>

<!-- ─── Hàng 4: Bản đồ nhiệt khung giờ vàng ─── -->
<div class="chart-section" id="heatmapSection" style="margin-bottom:24px;">
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:12px;">
    <h4 style="font-size:15px;font-weight:600;">Bản đồ nhiệt khung giờ vàng</h4>
    <div class="metric-switcher" id="heatmapMetricSwitcher">
      <button class="metric-btn" data-metric="add_to_cart">Thêm giỏ hàng</button>
      <button class="metric-btn" data-metric="reach_checkout">Thanh toán</button>
      <button class="metric-btn active" data-metric="purchase">Mua hàng</button>
    </div>
  </div>
  <div id="heatmapContainer" style="min-height:200px;"><p style="color:var(--text-muted);text-align:center;padding:40px;">Đang tải...</p></div>
  <div id="heatmapLegend" style="margin-top:12px;"></div>
</div>

<!-- ─── Hàng 5: Đơn hàng gần đây ─── -->
<div class="chart-section" style="padding:0;margin-bottom:24px;">
  <h4 style="font-size:15px;font-weight:600;padding:20px 20px 4px;">Đơn hàng gần đây</h4>
  <div style="padding:0 12px 8px;">
    <table class="data-table data-table-compact" style="border:none;border-radius:0;box-shadow:none;table-layout:fixed;width:100%;">
      <colgroup><col style="width:auto;"><col style="width:95px;"><col style="width:85px;"><col style="width:80px;"></colgroup>
      <thead><tr><th>Khách hàng</th><th>Tổng tiền</th><th>Trạng thái</th><th>Ngày</th></tr></thead>
      <tbody id="tbl-recentOrders"></tbody>
    </table>
  </div>
</div>

<!-- ─── Hàng 6: Truy cập nhanh ─── -->
<div style="margin-bottom:24px;">
  <h3 style="font-size:16px;font-weight:600;margin-bottom:12px;">Truy cập nhanh</h3>
  <div style="display:flex;gap:12px;flex-wrap:wrap;">
    <a href="/admin/products" class="quick-action-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg> Sản phẩm</a>
    <a href="/admin/orders" class="quick-action-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg> Đơn hàng</a>
    <a href="/admin/users" class="quick-action-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg> Người dùng</a>
    <a href="/admin/brands" class="quick-action-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg> Thương hiệu</a>
    <a href="/admin/categories" class="quick-action-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg> Danh mục</a>
    <a href="/admin/vouchers" class="quick-action-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 12H4"/><path d="M2 7h20"/><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M12 12v4"/><path d="M10 14h4"/></svg> Mã giảm giá</a>
    <a href="/admin/media" class="quick-action-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg> Media</a>
    <a href="/admin/settings" class="quick-action-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg> Cài đặt</a>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
var API_TOKEN = '<%= apiToken %>';
var H = { 'Authorization': 'Bearer ' + API_TOKEN };
function $(id) { return document.getElementById(id); }
function fmt(n) { return (n || 0).toLocaleString('vi-VN'); }
function fmtCurrency(n) { return fmt(n) + 'đ'; }
function escapeHtml(str) {
  if (!str) return '';
  return String(str).replace(/[&<>"']/g, function(m){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]||m; });
}
var statusBadge = { pending: '#f59e0b', processing: '#3b82f6', shipped: '#8b5cf6', delivered: '#22c55e', cancelled: '#ef4444' };

function todayStr() {
  var d = new Date();
  return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');
}

// ────── Gọi từng API riêng lẻ ──────
var today = todayStr();

Promise.all([
  fetch('/api/products?page=1&limit=1', { headers: H }).then(function(r){return r.json();}),
  fetch('/api/funnel/brand-retention', { headers: H }).then(function(r){return r.json();}),
  fetch('/api/orders/admin/orders?page=1&limit=10', { headers: H }).then(function(r){return r.json();}),
  fetch('/api/users?page=1&limit=1&role=USER', { headers: H }).then(function(r){return r.json();}),
  fetch('/api/visits', { headers: H }).then(function(r){return r.json();}),
  fetch('/api/categories', { headers: H }).then(function(r){return r.json();}),
  fetch('/api/products?stock=lowStock&page=1&limit=1', { headers: H }).then(function(r){return r.json();}),
  fetch('/api/orders/admin/orders?startDate='+today+'&endDate='+today+'&limit=100', { headers: H }).then(function(r){return r.json();}),
])
.then(function(results) {
  var prodRes = results[0].data || {};
  var retentionRes = results[1].data || {};
  var recentOrdersRes = results[2].data || {};
  var usersRes = results[3].data || {};
  var visitsRes = results[4].data || 0;
  var catRes = results[5].data || {};
  var lowStockRes = results[6].data || {};
  var todayOrdersRes = results[7].data || {};

  // ────── KPI Cards ──────
  $('kpi-totalProducts').textContent = fmt(prodRes.total || 0);

  var todayOrders = todayOrdersRes.orders || [];
  var revToday = todayOrders.reduce(function(s, o) { return s + (o.status !== 'cancelled' ? (o.totalAmount||0) : 0); }, 0);
  $('kpi-revenueToday').textContent = fmtCurrency(revToday);
  $('kpi-newOrdersToday').textContent = fmt(todayOrders.length);
  $('kpi-visitsToday').textContent = fmt(visitsRes);
  $('kpi-lowStockCount').textContent = fmt(lowStockRes.total || 0);
  $('kpi-totalUsers').textContent = fmt(usersRes.total || 0);

  // ────── Recent Orders Table ──────
  var orders = recentOrdersRes.orders || [];
  var tbody = $('tbl-recentOrders');
  orders.forEach(function(o) {
    var tr = document.createElement('tr');
    var dt = o.createdAt ? new Date(o.createdAt).toLocaleDateString('vi-VN') : '—';
    var name = escapeHtml(o.customerName||'—');
    tr.innerHTML = '<td style="font-weight:500;color:var(--text-primary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:0;">'+name+'</td>'+
      '<td style="font-weight:600;font-variant-numeric:tabular-nums;">'+fmtCurrency(o.totalAmount)+'</td>'+
      '<td><span style="display:inline-block;padding:1px 8px;border-radius:6px;font-size:11px;font-weight:600;color:#fff;background:'+(statusBadge[o.status]||'#999')+';">'+(o.status||'—')+'</span></td>'+
      '<td style="color:var(--text-muted);font-size:12px;font-variant-numeric:tabular-nums;">'+dt+'</td>';
    tbody.appendChild(tr);
  });
  if (!orders.length) tbody.innerHTML = '<tr><td colspan="4" style="text-align:center;padding:24px;color:var(--text-muted);font-size:13px;">Chưa có đơn hàng</td></tr>';

  // ────── Retention Chart: Giữ chân khách hàng (Stacked Bar) ──────
  var retData = retentionRes || [];
  if (retData.length && $('chartRetention')) {
    new Chart($('chartRetention').getContext('2d'), {
      type: 'bar',
      data: {
        labels: retData.map(function(d){ return d.brandName; }),
        datasets: [
          { label: 'Khách mới', data: retData.map(function(d){ return d.new; }), backgroundColor: '#3b82f6', borderRadius: 3 },
          { label: 'Khách quay lại', data: retData.map(function(d){ return d.returning; }), backgroundColor: '#C9A96E', borderRadius: 3 }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        scales: { x: { stacked: true }, y: { stacked: true, ticks: { callback: function(v){ return fmt(v); } } } },
        plugins: {
          legend: { labels: { usePointStyle: true, padding: 16, font: { size: 12 } } },
          tooltip: { callbacks: { label: function(ctx){ return ctx.dataset.label + ': ' + fmtCurrency(ctx.parsed.y); } } }
        }
      }
    });
  }

  // ────── Funnel Chart: Phễu chuyển đổi thương hiệu ──────
  var F = function(){ return $('funnelContainer'); };
  var S = function(){ return $('funnelBrandFilter'); };
  var dd = function(){ return S().querySelector('.custom-select-dropdown'); };
  var itemsWrap = function(){ return S().querySelector('.custom-select-items'); };
  var label = function(){ return S().querySelector('.custom-select-label'); };
  var searchInput = function(){ return S().querySelector('.custom-select-search'); };
  var currentBrandId = '';
  function renderFunnel(brandId) {
    currentBrandId = brandId;
    var name = label().textContent;
    F().innerHTML = '<div class="funnel-grid"><div class="funnel-brand">'+
      '<div class="funnel-name">'+escapeHtml(name)+'</div>'+
      '<div class="funnel-bars">'+
        '<div class="funnel-row"><span class="funnel-label">Lượt xem</span><div class="funnel-track"><div class="funnel-bar funnel-bar-skeleton" style="width:85%"></div></div><span class="funnel-val skeleton" style="display:inline-block;width:80px;height:18px;border-radius:4px;"></span></div>'+
        '<div class="funnel-row"><span class="funnel-label">Thêm giỏ hàng</span><div class="funnel-track"><div class="funnel-bar funnel-bar-skeleton" style="width:55%"></div></div><span class="funnel-val skeleton" style="display:inline-block;width:80px;height:18px;border-radius:4px;"></span></div>'+
        '<div class="funnel-row"><span class="funnel-label">Thanh toán</span><div class="funnel-track"><div class="funnel-bar funnel-bar-skeleton" style="width:30%"></div></div><span class="funnel-val skeleton" style="display:inline-block;width:80px;height:18px;border-radius:4px;"></span></div>'+
        '<div class="funnel-row"><span class="funnel-label">Mua hàng</span><div class="funnel-track"><div class="funnel-bar funnel-bar-skeleton" style="width:15%"></div></div><span class="funnel-val skeleton" style="display:inline-block;width:80px;height:18px;border-radius:4px;"></span></div>'+
      '</div></div></div>';
    var url = '/api/funnel/data';
    if (brandId) url += '?brandId=' + encodeURIComponent(brandId);
    fetch(url, { headers: H }).then(function(r){return r.json();}).then(function(res){
      if (!res.success) { F().innerHTML = '<p style="color:var(--text-muted);text-align:center;padding:40px;font-size:13px;">Lỗi tải dữ liệu</p>'; return; }
      if (!res.data || !res.data.length) {
        F().innerHTML = '<p style="color:var(--text-muted);text-align:center;padding:40px;font-size:13px;">Chưa có dữ liệu chuyển đổi</p>';
        return;
      }
      var html = '<div class="funnel-grid">';
      res.data.forEach(function(brand){
        var s = brand.stages;
        var maxVal = Math.max(s.views, 1);
        var pct = function(v){ return Math.max(2, (v/maxVal)*100); };
        var cv1 = s.views ? ((s.addToCart/s.views)*100).toFixed(0) : 0;
        var cv2 = s.addToCart ? ((s.checkout/s.addToCart)*100).toFixed(0) : 0;
        var cv3 = s.checkout ? ((s.purchases/s.checkout)*100).toFixed(0) : 0;
        html += '<div class="funnel-brand">'+
          '<div class="funnel-name">'+escapeHtml(brand.brandName)+'</div>'+
          '<div class="funnel-bars">'+
            '<div class="funnel-row"><span class="funnel-label">Lượt xem</span><div class="funnel-track"><div class="funnel-bar funnel-bar-views" style="width:'+pct(s.views)+'%"></div></div><span class="funnel-val">'+fmt(s.views)+'</span></div>'+
            '<div class="funnel-row"><span class="funnel-label">Thêm giỏ hàng</span><div class="funnel-track"><div class="funnel-bar funnel-bar-cart" style="width:'+pct(s.addToCart)+'%"></div></div><span class="funnel-val">'+fmt(s.addToCart)+' <span class="funnel-cv">'+cv1+'%</span></span></div>'+
            '<div class="funnel-row"><span class="funnel-label">Thanh toán</span><div class="funnel-track"><div class="funnel-bar funnel-bar-checkout" style="width:'+pct(s.checkout)+'%"></div></div><span class="funnel-val">'+fmt(s.checkout)+' <span class="funnel-cv">'+cv2+'%</span></span></div>'+
            '<div class="funnel-row"><span class="funnel-label">Mua hàng</span><div class="funnel-track"><div class="funnel-bar funnel-bar-purchase" style="width:'+pct(s.purchases)+'%"></div></div><span class="funnel-val">'+fmt(s.purchases)+' <span class="funnel-cv">'+cv3+'%</span></span></div>'+
          '</div></div>';
      });
      html += '</div>';
      F().innerHTML = html;
    }).catch(function(){
      F().innerHTML = '<p style="color:var(--text-muted);text-align:center;padding:40px;font-size:13px;">Lỗi tải dữ liệu</p>';
    });
  }
  if (F()) {
    // Init custom select
    var trigger = S().querySelector('.custom-select-trigger');
    trigger.addEventListener('click', function(e){
      e.stopPropagation();
      S().classList.toggle('open');
    });
    // Initial fetch to get brands, populate dropdown, then render first brand
    fetch('/api/funnel/data', { headers: H }).then(function(r){return r.json();}).then(function(res){
      if (!res.success || !res.brands || !res.brands.length) {
        F().innerHTML = '<p style="color:var(--text-muted);text-align:center;padding:40px;font-size:13px;">Chưa có dữ liệu chuyển đổi</p>';
        return;
      }
      res.brands.forEach(function(b){
        var item = document.createElement('div');
        item.className = 'custom-select-item';
        item.dataset.value = b.brandId;
        item.textContent = b.brandName;
        item.addEventListener('click', function(){
          selectBrand(b.brandId, b.brandName);
        });
        itemsWrap().appendChild(item);
      });
      // Search filter
      if (searchInput()) {
        searchInput().addEventListener('input', function(){
          var q = this.value.toLowerCase().trim();
          itemsWrap().querySelectorAll('.custom-select-item').forEach(function(el){
            el.style.display = (!q || el.textContent.toLowerCase().includes(q)) ? '' : 'none';
          });
        });
        searchInput().addEventListener('click', function(e){ e.stopPropagation(); });
      }
      function selectBrand(id, name) {
            label().textContent = name;
            itemsWrap().querySelectorAll('.custom-select-item').forEach(function(el){ el.classList.remove('active'); });
            var active = itemsWrap().querySelector('.custom-select-item[data-value="'+id+'"]');
            if (active) active.classList.add('active');
            S().classList.remove('open');
            if (searchInput()) { searchInput().value = ''; }
            currentBrandId = id;
            renderFunnel(id);
            renderTrend(id, getActiveMetric());
            renderHeatmap(id, getHeatmapMetric());
          }
          // Select first brand
          var first = itemsWrap().querySelector('.custom-select-item');
          if (first) {
            selectBrand(first.dataset.value, first.textContent);
          }
    }).catch(function(){
      F().innerHTML = '<p style="color:var(--text-muted);text-align:center;padding:40px;font-size:13px;">Lỗi tải dữ liệu</p>';
    });
    // Close dropdown on outside click
    document.addEventListener('click', function(){
      S().classList.remove('open');
    });
  }

  // ────── Trend Chart: Xu hướng hiệu suất ──────
  var trendChart = null;
  var TR = function(){ return $('chartTrend'); };
  function renderTrend(brandId, metric) {
    if (!brandId) return;
    fetch('/api/funnel/brand-timeseries?brandId='+encodeURIComponent(brandId)+'&metric='+encodeURIComponent(metric), { headers: H }).then(function(r){return r.json();}).then(function(res){
      if (!res.success || !res.data || !res.data.current || !res.data.current.length) {
        if (trendChart) { trendChart.destroy(); trendChart = null; }
        return;
      }
      var d = res.data;
      var labels = d.current.map(function(p){ return p.date.substring(5); });
      var curVals = d.current.map(function(p){ return p.value; });
      var bmkVals = d.benchmark.map(function(p){ return p.value; });
      var maxV = Math.max.apply(null, curVals.concat(bmkVals)) || 1;
      if (trendChart) { trendChart.destroy(); trendChart = null; }
      if (!TR()) return;
      trendChart = new Chart(TR().getContext('2d'), {
        type: 'line',
        data: {
          labels: labels,
          datasets: [
            {
              label: 'Kỳ trước',
              data: bmkVals,
              borderColor: 'rgba(148,163,184,0.5)',
              backgroundColor: 'rgba(148,163,184,0.12)',
              borderDash: [6, 3],
              borderWidth: 1.5,
              fill: true,
              tension: 0.3,
              pointRadius: 0,
              pointHitRadius: 4,
            },
            {
              label: 'Hiện tại',
              data: curVals,
              borderColor: '#C9A96E',
              backgroundColor: 'rgba(201,169,110,0.06)',
              borderWidth: 2.5,
              fill: false,
              tension: 0.3,
              pointRadius: 4,
              pointBackgroundColor: '#C9A96E',
              pointBorderColor: '#fff',
              pointBorderWidth: 2,
            }
          ]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            legend: { labels: { usePointStyle: true, padding: 16, font: { size: 12 } } },
            tooltip: {
              callbacks: {
                label: function(ctx){ return ctx.dataset.label + ': ' + fmt(ctx.parsed.y); }
              }
            }
          },
          scales: {
            x: { grid: { display: false }, ticks: { font: { size: 11 }, color: '#787774' } },
            y: {
              beginAtZero: true, max: Math.ceil(maxV * 1.2),
              grid: { color: 'rgba(201,169,110,0.06)' },
              ticks: { font: { size: 11 }, color: '#787774', stepSize: Math.max(1, Math.ceil(maxV/5)) }
            }
          }
        }
      });
    }).catch(function(){});
  }
  function getActiveMetric() {
    var active = $('metricSwitcher') ? $('metricSwitcher').querySelector('.metric-btn.active') : null;
    return active ? active.dataset.metric : 'add_to_cart';
  }
  // Wire metric switcher buttons
  if ($('metricSwitcher')) {
    $('metricSwitcher').querySelectorAll('.metric-btn').forEach(function(btn){
      btn.addEventListener('click', function(){
        $('metricSwitcher').querySelectorAll('.metric-btn').forEach(function(b){ b.classList.remove('active'); });
        this.classList.add('active');
        if (currentBrandId) renderTrend(currentBrandId, this.dataset.metric);
      });
    });
  }

  // ────── Heatmap: Bản đồ nhiệt khung giờ vàng ──────
  var HC = function(){ return $('heatmapContainer'); };
  var HL = function(){ return $('heatmapLegend'); };
  function renderHeatmap(brandId, metric) {
    if (!brandId) return;
    HC().innerHTML = '<p style="color:var(--text-muted);text-align:center;padding:40px;">Đang tải...</p>';
    HL().innerHTML = '';
    fetch('/api/funnel/brand-heatmap?brandId='+encodeURIComponent(brandId)+'&metric='+encodeURIComponent(metric), { headers: H }).then(function(r){return r.json();}).then(function(res){
      if (!res.success || !res.data) {
        HC().innerHTML = '<p style="color:var(--text-muted);text-align:center;padding:40px;font-size:13px;">Chưa có dữ liệu</p>';
        return;
      }
      var d = res.data;
      // Build grid table
      var html = '<div class="heatmap-grid"><div class="heatmap-corner"></div>';
      d.days.forEach(function(day){ html += '<div class="heatmap-header">'+day+'</div>'; });
      for (var h = 0; h < 24; h++) {
        html += '<div class="heatmap-hour">'+String(h).padStart(2,'0')+':00</div>';
        for (var col = 0; col < 7; col++) {
          var val = d.matrix[h][col];
          var pct = d.max > 0 ? (val / d.max) : 0;
          // color from light gray to red
          var r = Math.round(220 + (35 * (1-pct)));
          var g = Math.round(220 - (120 * pct));
          var b = Math.round(220 - (160 * pct));
          var bg = 'rgb('+r+','+g+','+b+')';
          var txtColor = pct > 0.5 ? '#fff' : '#2F3437';
          html += '<div class="heatmap-cell" style="background:'+bg+';color:'+txtColor+'" title="'+dayLabelsFull(col)+', '+h+':00: '+fmt(val)+'">'+(val > 0 ? fmt(val) : '')+'</div>';
        }
      }
      html += '</div>';
      HC().innerHTML = html;
      // Build legend
      var steps = 5;
      var lhtml = '<div class="heatmap-legend"><span style="font-size:12px;color:var(--text-muted);margin-right:8px;">Thấp</span>';
      for (var s = 0; s < steps; s++) {
        var p = s / (steps-1);
        var lr = Math.round(220 + (35 * (1-p)));
        var lg = Math.round(220 - (120 * p));
        var lb = Math.round(220 - (160 * p));
        lhtml += '<div class="heatmap-legend-cell" style="background:rgb('+lr+','+lg+','+lb+')"></div>';
      }
      lhtml += '<span style="font-size:12px;color:var(--text-muted);margin-left:8px;">Cao</span></div>';
      HL().innerHTML = lhtml;
    }).catch(function(){
      HC().innerHTML = '<p style="color:var(--text-muted);text-align:center;padding:40px;font-size:13px;">Lỗi tải dữ liệu</p>';
    });
  }
  function dayLabelsFull(col) {
    return ['Thứ Hai','Thứ Ba','Thứ Tư','Thứ Năm','Thứ Sáu','Thứ Bảy','Chủ Nhật'][col];
  }
  function getHeatmapMetric() {
    var active = $('heatmapMetricSwitcher') ? $('heatmapMetricSwitcher').querySelector('.metric-btn.active') : null;
    return active ? active.dataset.metric : 'purchase';
  }
  // Wire heatmap metric switcher
  if ($('heatmapMetricSwitcher')) {
    $('heatmapMetricSwitcher').querySelectorAll('.metric-btn').forEach(function(btn){
      btn.addEventListener('click', function(){
        $('heatmapMetricSwitcher').querySelectorAll('.metric-btn').forEach(function(b){ b.classList.remove('active'); });
        this.classList.add('active');
        if (currentBrandId) renderHeatmap(currentBrandId, this.dataset.metric);
      });
    });
  }

  // ────── 7-day Revenue Chart (Pre-aggregated + Redis cached) ──────
  fetch('/api/admin/daily-summary?days=7', { headers: H })
  .then(function(r){return r.json();})
  .then(function(res){
    if (!res.success || !res.data || !res.data.length) return;
    var labels=[], revenue=[], orders=[];
    res.data.forEach(function(d){
      var dt = new Date(d.date);
      labels.push(dt.toLocaleDateString('vi-VN', { weekday:'short', day:'2-digit', month:'2-digit' }));
      revenue.push(Math.round(d.revenue / 1000));
      orders.push(d.orders);
    });
    if ($('chartRevenue7d')) new Chart($('chartRevenue7d').getContext('2d'), {
      type: 'line',
      data: {
        labels: labels,
        datasets: [
          { label: 'Doanh thu (nghìn VND)', data: revenue, borderColor: '#C9A96E', backgroundColor: 'rgba(201,169,110,0.08)', fill: true, tension: 0.3, pointRadius: 3, yAxisID: 'y' },
          { label: 'Đơn hàng', data: orders, borderColor: '#3b82f6', backgroundColor: 'rgba(59,130,246,0.06)', fill: true, tension: 0.3, pointRadius: 3, yAxisID: 'y1' }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: { legend: { labels: { usePointStyle: true, padding: 16 } } },
        scales: {
          x: { ticks: { maxTicksLimit: 7 } },
          y: { type: 'linear', position: 'left', title: { display: true, text: 'nghìn VND' }, ticks: { callback: function(v){return v+'K';} } },
          y1: { type: 'linear', position: 'right', title: { display: true, text: 'Đơn hàng' }, ticks: { stepSize: 1 }, grid: { drawOnChartArea: false } }
        }
      }
    });
  })
  .catch(function(err) { console.error('Daily summary fetch failed:', err); });
})
.catch(function(err) { console.error('Dashboard fetch failed:', err); });
</script>
