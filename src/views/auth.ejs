<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đăng nhập - L'essence</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: #FFFFFF;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
      color: #1A1A1A;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overflow-x: hidden;
    }

    /* ===== WRAPPER với animation width/height ===== */
    .form-wrapper {
      position: relative;
      width: 100%;
      max-width: 420px;
      transition: max-width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .form-wrapper.register-mode {
      max-width: 640px;
    }

    .back-badge {
      position: absolute;
      top: -16px;
      left: -16px;
      z-index: 10;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 8px 16px;
      background: #FFFFFF;
      border: 1px solid #E8E8E8;
      border-radius: 20px;
      color: #666666;
      text-decoration: none;
      font-size: 13px;
      font-weight: 500;
      transition: all 0.2s ease;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .back-badge:hover {
      background: #FFFFFF;
      color: #1A1A1A;
      border-color: #B8944F;
    }
    @media (max-width: 680px) {
      .back-badge {
        top: -12px;
        left: 50%;
        transform: translateX(-50%);
      }
      .form-wrapper, .form-wrapper.register-mode {
        max-width: 420px;
      }
    }

    .container {
      background: #FFFFFF;
      border: 1px solid #E8E8E8;
      border-radius: 16px;
      padding: 48px 40px;
      width: 100%;
      box-shadow: 0 4px 24px rgba(0,0,0,0.06);
      position: relative;
      overflow: hidden;
      min-height: 380px;
      transition: min-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .container.register-active {
      min-height: 520px;
    }

    /* ===== FORM PANELS ===== */
    .form-panel {
      position: absolute;
      top: 48px;
      left: 40px;
      right: 40px;
      opacity: 0;
      transform: translateY(12px);
      transition: opacity 0.35s ease, transform 0.35s ease;
      pointer-events: none;
    }
    .form-panel.active {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
      position: relative;
      top: 0;
      left: 0;
      right: 0;
    }
    .form-panel.exit-left {
      opacity: 0;
      transform: translateX(-24px);
    }
    .form-panel.exit-right {
      opacity: 0;
      transform: translateX(24px);
    }

    .logo {
      text-align: center;
      margin-bottom: 32px;
    }
    .logo img { width: 48px; height: 48px; object-fit: contain; }
    .logo h1 {
      color: #1A1A1A;
      font-size: 24px;
      margin-top: 12px;
      font-weight: 700;
      letter-spacing: 1px;
      transition: all 0.35s ease;
    }
    .logo .subtitle {
      color: #999999;
      font-size: 14px;
      margin-top: 4px;
      font-weight: 400;
      transition: all 0.35s ease;
    }

    /* --- Register grid --- */
    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0 24px;
    }
    @media (max-width: 540px) {
      .form-grid {
        grid-template-columns: 1fr;
        gap: 0;
      }
    }

    .form-group { margin-bottom: 18px; }
    label {
      display: block;
      color: #666666;
      font-size: 13px;
      font-weight: 500;
      margin-bottom: 6px;
    }
    input {
      width: 100%;
      padding: 12px 16px;
      background: #FFFFFF;
      border: 1px solid #E8E8E8;
      border-radius: 10px;
      color: #1A1A1A;
      font-size: 15px;
      outline: none;
      transition: all 0.2s ease;
      font-family: inherit;
    }
    input:focus {
      border-color: #B8944F;
      box-shadow: 0 0 0 3px rgba(201,169,110,0.12);
    }
    input::placeholder { color: #999999; }

    .error-msg {
      background: rgba(239,68,68,0.08);
      border: 1px solid rgba(239,68,68,0.2);
      color: #DC2626;
      padding: 10px 14px;
      border-radius: 10px;
      font-size: 13px;
      margin-bottom: 20px;
      display: none;
    }
    .error-msg.show { display: block; }
    .success-msg {
      background: rgba(34,197,94,0.08);
      border: 1px solid rgba(34,197,94,0.2);
      color: #16A34A;
      padding: 10px 14px;
      border-radius: 10px;
      font-size: 13px;
      margin-bottom: 20px;
      display: none;
    }
    .success-msg.show { display: block; }

    .field-error {
      color: #DC2626;
      font-size: 12px;
      margin-top: 4px;
      display: none;
    }
    .field-error.show { display: block; }

    .btn {
      width: 100%;
      padding: 13px;
      background: #C9A96E;
      color: #0A0A0A;
      border: none;
      border-radius: 10px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
      font-family: inherit;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    .btn:hover { background: #B8944F; transform: translateY(-1px); }
    .btn:active { transform: translateY(0); }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

    .spinner { display: none; }
    .btn.loading .spinner { display: inline-flex; }
    .btn.loading .btn-text { display: none; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .spinner-icon {
      display: inline-block;
      width: 18px;
      height: 18px;
      border: 2px solid rgba(10,10,10,0.15);
      border-top-color: #0A0A0A;
      border-radius: 50%;
      animation: spin 0.6s linear infinite;
    }

    .turnstile-container { margin-bottom: 20px; display: flex; justify-content: center; }

    .footer { text-align: center; margin-top: 24px; }
    .footer a {
      color: #666666;
      text-decoration: none;
      font-size: 14px;
      transition: color 0.2s ease;
      cursor: pointer;
    }
    .footer a:hover { color: #B8944F; }

    /* Common section hidden in panel, shown below */
    .oauth-section { margin-top: 16px; }
    .oauth-divider {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
    }
    .oauth-divider .line {
      flex: 1;
      height: 1px;
      background: #E8E8E8;
    }
    .oauth-divider span {
      color: #999999;
      font-size: 13px;
      white-space: nowrap;
    }
    .google-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      width: 100%;
      padding: 12px;
      background: #FFFFFF;
      border: 1px solid #E8E8E8;
      border-radius: 10px;
      color: #1A1A1A;
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
      transition: all 0.2s ease;
      cursor: pointer;
    }
    .google-btn:hover {
      background: #F5F5F5;
      border-color: #D0D0D0;
    }
  </style>
  <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
</head>
<body>
  <div class="form-wrapper" id="formWrapper">
    <a href="http://localhost:3000" class="back-badge">
      <span>↩</span> Quay lại cửa hàng
    </a>
    <div class="container" id="container">
      <!-- ========== LOGO ========== -->
      <div class="logo">
        <img src="https://l-essence.vercel.app/logo.png" alt="L'essence" onerror="this.style.display='none'">
        <h1>L'essence</h1>
        <p class="subtitle" id="subtitle">Đăng nhập để tiếp tục</p>
      </div>

      <!-- ========== ERROR / SUCCESS ========== -->
      <div id="errorBox" class="error-msg"></div>
      <div id="successBox" class="success-msg"></div>

      <!-- ========== LOGIN PANEL ========== -->
      <div class="form-panel active" id="loginPanel">
        <form id="loginForm">
          <div class="form-group">
            <label for="loginEmail">Email</label>
            <input type="email" id="loginEmail" name="email" placeholder="your@email.com" required autocomplete="email">
          </div>
          <div class="form-group">
            <label for="loginPassword">Mật khẩu</label>
            <input type="password" id="loginPassword" name="password" placeholder="••••••••" required autocomplete="current-password">
          </div>
          <div class="turnstile-container" id="loginTurnstile">
            <div class="cf-turnstile" data-sitekey="<%= turnstileSiteKey %>" data-theme="light"></div>
          </div>
          <button type="submit" class="btn" id="loginSubmitBtn">
            <span class="btn-text">Đăng nhập</span>
            <span class="spinner"><span class="spinner-icon"></span></span>
          </button>
        </form>

        <div class="oauth-section">
          <div class="oauth-divider">
            <div class="line"></div>
            <span>hoặc</span>
            <div class="line"></div>
          </div>
          <a href="/api/auth/google" class="google-btn">
            <svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Đăng nhập bằng Google
          </a>
        </div>

        <div class="footer">
          <a onclick="switchMode('register')">Chưa có tài khoản? Đăng ký</a>
        </div>
      </div>

      <!-- ========== REGISTER PANEL ========== -->
      <div class="form-panel" id="registerPanel">
        <form id="registerForm" novalidate>
          <div class="form-grid grid-2-cols">
            <div class="form-group">
              <label for="regUsername">Tên đăng nhập</label>
              <input type="text" id="regUsername" name="username" placeholder="username" required autocomplete="username">
              <div class="field-error" id="usernameError">Tên đăng nhập tối thiểu 3 ký tự</div>
            </div>
            <div class="form-group">
              <label for="regPassword">Mật khẩu</label>
              <input type="password" id="regPassword" name="password" placeholder="Ít nhất 6 ký tự" required autocomplete="new-password">
              <div class="field-error" id="passwordError">Mật khẩu phải có ít nhất 6 ký tự</div>
            </div>
            <div class="form-group">
              <label for="regEmail">Email</label>
              <input type="email" id="regEmail" name="email" placeholder="your@email.com" required autocomplete="email">
              <div class="field-error" id="emailError">Email không hợp lệ</div>
            </div>
            <div class="form-group">
              <label for="regConfirmPassword">Xác nhận mật khẩu</label>
              <input type="password" id="regConfirmPassword" name="confirmPassword" placeholder="Nhập lại mật khẩu" required autocomplete="new-password">
              <div class="field-error" id="confirmPasswordError">Mật khẩu xác nhận không khớp</div>
            </div>
          </div>
          <div class="turnstile-container" id="registerTurnstile">
            <div class="cf-turnstile" data-sitekey="<%= turnstileSiteKey %>" data-theme="light"></div>
          </div>
          <button type="submit" class="btn" id="registerSubmitBtn">
            <span class="btn-text">Đăng ký</span>
            <span class="spinner"><span class="spinner-icon"></span></span>
          </button>
        </form>

        <div class="oauth-section">
          <div class="oauth-divider">
            <div class="line"></div>
            <span>hoặc</span>
            <div class="line"></div>
          </div>
          <a href="/api/auth/google" class="google-btn">
            <svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
            Đăng nhập bằng Google
          </a>
        </div>

        <div class="footer">
          <a onclick="switchMode('login')">Đã có tài khoản? Đăng nhập</a>
        </div>
      </div>
    </div>
  </div>

  <script>
    // ===== STATE =====
    let currentMode = '<%= mode %>'; // 'login' hoặc 'register'
    let isTransitioning = false;
    let turnstileWidgetId = null;

    const formWrapper = document.getElementById('formWrapper');
    const container = document.getElementById('container');
    const subtitle = document.getElementById('subtitle');
    const loginPanel = document.getElementById('loginPanel');
    const registerPanel = document.getElementById('registerPanel');
    const errorBox = document.getElementById('errorBox');
    const successBox = document.getElementById('successBox');
    const loginForm = document.getElementById('loginForm');
    const registerForm = document.getElementById('registerForm');
    const loginSubmitBtn = document.getElementById('loginSubmitBtn');
    const registerSubmitBtn = document.getElementById('registerSubmitBtn');

    // ===== INIT =====
    function init() {
      if (currentMode === 'register') {
        switchMode('register', false);
      }

      // URL params
      const params = new URLSearchParams(window.location.search);
      const errorParam = params.get('error');
      if (errorParam) {
        errorBox.textContent = decodeURIComponent(errorParam);
        errorBox.classList.add('show');
      }
      const successParam = params.get('success');
      if (successParam) {
        successBox.textContent = decodeURIComponent(successParam);
        successBox.classList.add('show');
      }
    }

    // ===== SWITCH MODE =====
    function switchMode(mode, animate = true) {
      if (isTransitioning || currentMode === mode) return;
      isTransitioning = true;
      document.title = mode === 'login' ? 'Đăng nhập - L\'essence' : 'Đăng ký - L\'essence';

      const fromPanel = currentMode === 'register' ? registerPanel : loginPanel;
      const toPanel = mode === 'register' ? registerPanel : loginPanel;

      // 1. Animate wrapper width
      if (mode === 'register') {
        formWrapper.classList.add('register-mode');
        container.classList.add('register-active');
        subtitle.textContent = 'Tạo tài khoản mới';
      } else {
        formWrapper.classList.remove('register-mode');
        container.classList.remove('register-active');
        subtitle.textContent = 'Đăng nhập đệtiếp tục';
      }

      // 2. Slide out current panel
      if (animate) {
        const exitClass = mode === 'register' ? 'exit-left' : 'exit-right';
        fromPanel.classList.add(exitClass);
        fromPanel.classList.remove('active');
      } else {
        fromPanel.classList.remove('active');
      }

      // 3. Slide in new panel
      setTimeout(() => {
        fromPanel.classList.remove('exit-left', 'exit-right');
        toPanel.classList.add('active');
        currentMode = mode;

        // Render Turnstile nếu cần
        renderTurnstile(mode);

        // Clear messages
        errorBox.classList.remove('show');
        successBox.classList.remove('show');

        isTransitioning = false;
      }, animate ? 300 : 50);
    }

    // ===== TURNSTILE (lazy render) =====
    function renderTurnstile(mode) {
      const container = mode === 'register' ? document.getElementById('registerTurnstile') : document.getElementById('loginTurnstile');
      // Nếu đã có widget thì skip
      if (container && container.querySelector('.cf-turnstile')) return;

      // Reset container
      if (container) {
        container.innerHTML = '';
        const div = document.createElement('div');
        div.className = 'cf-turnstile';
        div.setAttribute('data-sitekey', '<%= turnstileSiteKey %>');
        div.setAttribute('data-theme', 'light');
        container.appendChild(div);

        // Re-render Turnstile
        if (window.turnstile) {
          window.turnstile.render(div);
        }
      }
    }

    // ===== VALIDATION =====
    const registerFields = {
      username: { el: document.getElementById('regUsername'), error: document.getElementById('usernameError') },
      email: { el: document.getElementById('regEmail'), error: document.getElementById('emailError') },
      password: { el: document.getElementById('regPassword'), error: document.getElementById('passwordError') },
      confirmPassword: { el: document.getElementById('regConfirmPassword'), error: document.getElementById('confirmPasswordError') },
    };

    function validateRegister() {
      let valid = true;
      const data = {
        username: registerFields.username.el.value.trim(),
        email: registerFields.email.el.value.trim(),
        password: registerFields.password.el.value,
        confirmPassword: registerFields.confirmPassword.el.value,
      };

      if (data.username.length < 3) { registerFields.username.error.classList.add('show'); valid = false; }
      else { registerFields.username.error.classList.remove('show'); }

      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(data.email)) { registerFields.email.error.classList.add('show'); valid = false; }
      else { registerFields.email.error.classList.remove('show'); }

      if (data.password.length < 6) { registerFields.password.error.classList.add('show'); valid = false; }
      else { registerFields.password.error.classList.remove('show'); }

      if (data.password !== data.confirmPassword) { registerFields.confirmPassword.error.classList.add('show'); valid = false; }
      else { registerFields.confirmPassword.error.classList.remove('show'); }

      return valid ? data : null;
    }

    function getTurnstileToken() {
      const el = document.querySelector('.cf-turnstile[data-sitekey]');
      return el?.querySelector?.('[name="cf-turnstile-response"]')?.value || '';
    }

    // ===== LOGIN SUBMIT =====
    loginForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBox.classList.remove('show');
      loginSubmitBtn.classList.add('loading');
      loginSubmitBtn.disabled = true;

      const turnstileToken = getTurnstileToken();
      if (!turnstileToken) {
        errorBox.textContent = 'Vui lòng xác minh bạn không phải là robot';
        errorBox.classList.add('show');
        loginSubmitBtn.classList.remove('loading');
        loginSubmitBtn.disabled = false;
        return;
      }

      const data = {
        email: document.getElementById('loginEmail').value,
        password: document.getElementById('loginPassword').value,
        turnstileToken
      };

      try {
        const res = await fetch('/api/auth/login-page', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const json = await res.json();
        if (json.success) {
          window.location.href = json.redirectUrl;
        } else {
          errorBox.textContent = json.message || 'Đăng nhập thất bại';
          errorBox.classList.add('show');
          // Reset Turnstile after failed attempt
          if (window.turnstile) window.turnstile.reset();
        }
      } catch (err) {
        errorBox.textContent = 'Lỗi kết nối đến máy chủ';
        errorBox.classList.add('show');
      } finally {
        loginSubmitBtn.classList.remove('loading');
        loginSubmitBtn.disabled = false;
      }
    });

    // ===== REGISTER SUBMIT =====
    registerForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBox.classList.remove('show');
      successBox.classList.remove('show');

      const turnstileToken = getTurnstileToken();
      if (!turnstileToken) {
        errorBox.textContent = 'Vui lòng xác minh bạn không phải là robot';
        errorBox.classList.add('show');
        return;
      }

      const data = validateRegister();
      if (!data) return;

      data.turnstileToken = turnstileToken;
      registerSubmitBtn.classList.add('loading');
      registerSubmitBtn.disabled = true;

      try {
        const res = await fetch('/api/auth/register-page', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const json = await res.json();
        if (json.success) {
          successBox.textContent = 'Đăng ký thành công! Đang chuyển đến trang đăng nhập...';
          successBox.classList.add('show');
          setTimeout(() => {
            switchMode('login');
          }, 1500);
        } else {
          errorBox.textContent = json.message || 'Đăng ký thất bại';
          errorBox.classList.add('show');
          if (window.turnstile) window.turnstile.reset();
        }
      } catch (err) {
        errorBox.textContent = 'Lỗi kết nối đến máy chủ';
        errorBox.classList.add('show');
      } finally {
        registerSubmitBtn.classList.remove('loading');
        registerSubmitBtn.disabled = false;
      }
    });

    init();
  </script>
</body>
</html>
